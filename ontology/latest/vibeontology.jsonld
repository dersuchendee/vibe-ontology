    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Un ruolo svolto da un agente come creatore o contributore alla produzione artistica."
      },
      {
        "@language": "en",
        "@value": "role played by an agent as a creator or contributor to artistic production."
      },
      {
        "@language": "nl",
        "@value": "rol gespeeld door een agent als maker van of bijdrager aan artistieke productie."
      },
      {
        "@language": "ja",
        "@value": "芸術制作の創造者または貢献者としてエージェントが担う役割。"
      },
      {
        "@language": "ru",
        "@value": "Роль, которую исполняет агент как создатель или участник процесса художественного производства."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Artist Role"
      },
      {
        "@language": "it",
        "@value": "Ruolo di artista"
      },
      {
        "@language": "nl",
        "@value": "Kunstenaarsrol"
      },
      {
        "@language": "ja",
        "@value": "アーティストの役割"
      },
      {
        "@language": "ru",
        "@value": "Роль художника"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
