        "@language": "en",
        "@value": "representativeness type"
      },
      {
        "@language": "it",
        "@value": "tipo di rappresentatività"
      },
      {
        "@language": "nl",
        "@value": "representativiteit type"
      },
      {
        "@language": "ja",
        "@value": "象徴性タイプ"
      },
      {
        "@language": "ru",
        "@value": "тип репрезентативности"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/influenced",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega un'Estetica a un'altra Estetica che essa ha influenzato in termini di stile, motivi o valori, o altro."
      },
      {
        "@language": "en",
        "@value": "Relates an Aesthetic to another Aesthetic that it has influenced in terms of style, motifs, values, or other."
      },
      {
        "@language": "nl",
        "@value": "Verbindt een esthetiek met een andere esthetiek die het heeft beïnvloed op het gebied van stijl, motieven, waarden of anderszins."
      },
      {
        "@language": "ja",
        "@value": "美学と、それがスタイル、モチーフ、価値観などの点で影響を与えた別の美学を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает эстетику с другой эстетикой, на которую она оказала влияние (в стиле, мотивах, ценностях и т. д.)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha influenzato"
      },
      {
        "@language": "en",
        "@value": "influenced"
      },
      {
        "@language": "nl",
        "@value": "beïnvloedde"
      },
      {
        "@language": "ja",
        "@value": "影響を与えた"
      },
      {
        "@language": "ru",
        "@value": "оказала влияние на"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/relatedTo"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/influencedBy"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/musicDimension",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
