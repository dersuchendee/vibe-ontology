        "@value": "Collega una RepresentativeAssociation all'entità considerata rappresentativa dell'Estetica."
      },
      {
        "@language": "en",
        "@value": "Links a RepresentativeAssociation to the entity that is considered representative of the Aesthetic."
      },
      {
        "@language": "nl",
        "@value": "Koppelt een RepresentativeAssociation aan de entiteit die als representatief voor de esthetiek wordt beschouwd."
      },
      {
        "@language": "ja",
        "@value": "RepresentativeAssociationと、美学の象徴的な表象と見なされるエンティティを結びつける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает репрезентативную ассоциацию с сущностью, которая считается характерной для данной эстетики."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/RepresentativeAssociation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "con entità"
      },
      {
        "@language": "en",
        "@value": "with entity"
      },
      {
        "@language": "nl",
        "@value": "met entiteit"
      },
      {
        "@language": "ja",
        "@value": "対象エンティティ"
      },
      {
        "@language": "ru",
        "@value": "с сущностью"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
