  {
    "@id": "https://w3id.org/vibe-ontology/InteriorDesign",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A form of architectural work focused on the design of interior spaces."
      },
      {
        "@language": "it",
        "@value": "Una forma di progettazione architettonica focalizzata sugli spazi interni."
      },
      {
        "@language": "nl",
        "@value": "Een vorm van architectonisch werk gericht op het ontwerpen van binnenruimtes."
      },
      {
        "@language": "ja",
        "@value": "内部空間のデザインに焦点を当てた建築作品の形態。"
      },
      {
        "@language": "ru",
        "@value": "Форма архитектурной работы, ориентированная на проектирование внутренних пространств."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Design d’interni"
      },
      {
        "@language": "en",
        "@value": "Interior Design"
      },
      {
        "@language": "nl",
        "@value": "Interieurontwerp"
      },
      {
        "@language": "ja",
        "@value": "インテリアデザイン"
      },
      {
        "@language": "ru",
        "@value": "Дизайн интерьера"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/ArchitecturalWork"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/relatedTo",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty",
      "http://www.w3.org/2002/07/owl#SymmetricProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A general symmetric relation indicating that an Aesthetic is related to another entity in some culturally relevant way. Serves as a superproperty for more specific relation types."
      },
      {
        "@language": "it",
        "@value": "Una relazione simmetrica generale che indica che un'Estetica è correlata a un'altra entità in modo culturalmente rilevante. Funge da superpropietà per tipi di relazione più specifici."
      },
      {
        "@language": "nl",
        "@value": "Een algemene symmetrische relatie die aangeeft dat een esthetiek gerelateerd is aan een andere entiteit op een cultureel relevante manier. Dient als superproperty voor specifiekere relatietypen."
      },
      {
        "@language": "ja",
        "@value": "美学が文化的に関連する方法で別のエンティティと関連することを示す一般的な対称関係。より具体的な関係タイプのスーパープロパティとして機能する。"
      },
      {
        "@language": "ru",
        "@value": "Общее симметричное отношение, указывающее на культурную связь эстетики с другой сущностью. Служит суперсвойством для более специфичных типов отношений."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "associato a"
      },
      {
        "@language": "en",
        "@value": "related to"
      },
      {
        "@language": "nl",
        "@value": "gerelateerd aan"
      },
      {
        "@language": "ja",
        "@value": "関連する"
      },
      {
        "@language": "ru",
        "@value": "связано с"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasLocationOfOrigin",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Specifica la collocazione geografica o digitale in cui un'Estetica ha avuto origine."
      },
      {
        "@language": "en",
        "@value": "Specifies the geographic or digital location where an Aesthetic first originated."
      },
      {
        "@language": "nl",
        "@value": "Specificeert de geografische of digitale locatie waar een esthetiek voor het eerst is ontstaan."
      },
      {
        "@language": "ja",
        "@value": "美学と、それが最初に発祥した物理的またはデジタルの空間的場所を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Указывает географическое или цифровое местоположение, в котором эстетика возникла впервые."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha luogo di origine"
      },
      {
        "@language": "en",
        "@value": "has location of origin"
      },
      {
        "@language": "nl",
        "@value": "heeft locatie van oorsprong"
      },
      {
        "@language": "ja",
        "@value": "発祥地"
      },
      {
        "@language": "ru",
        "@value": "место происхождения"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Location"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/hasLocation"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/RepresentativeAssociation",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A reified relation linking an Aesthetic to an entity that is considered representative of it. Such associations encode the mechanisms through which an aesthetic is recognized and constructed, and may be qualified by temporal scope, degree of representativeness, or role (e.g., primary)."
      },
      {
        "@language": "it",
        "@value": "Una relazione reificata che collega un’Estetica a un’entità considerata rappresentativa di essa. Tali associazioni codificano i meccanismi attraverso cui un’estetica viene riconosciuta e costruita, e possono essere qualificate rispetto all’estensione temporale, al grado di rappresentatività o al ruolo (ad esempio, primario)."
      },
      {
        "@language": "nl",
        "@value": "Een gereificeerde relatie die een esthetiek koppelt aan een entiteit die als representatief hiervoor wordt beschouwd. Dergelijke associaties coderen de mechanismen waardoor een esthetiek wordt herkend en geconstrueerd, en kunnen worden gekwalificeerd door temporele reikwijdte, mate van representativiteit of rol (bijv. primair)."
      },
      {
        "@language": "ja",
        "@value": "美学と、その象徴的な表象であるエンティティとを繋ぐ関係を実体化したクラス。これらの関連は美学が認識され構築されるメカニズムを定めるものであり、時間的範囲、代表性の度合い、あるいは（主従などの）役割によって詳細化される。"
      },
      {
        "@language": "ru",
        "@value": "Реифицированное отношение, связывающее эстетику с сущностью, которая считается репрезентативной для неё. Такие ассоциации кодируют механизмы, посредством которых эстетика распознается и конструируется, и могут быть уточнены временными рамками, степенью репрезентативности или ролью (например, основной)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Associazione rappresentativa"
      },
      {
        "@language": "en",
        "@value": "Representative Association"
      },
      {
        "@language": "nl",
        "@value": "Representatieve associatie"
      },
      {
        "@language": "ja",
        "@value": "象徴的な関連"
      },
      {
        "@language": "ru",
        "@value": "Репрезентативная ассоциация"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2004/02/skos/core#narrower",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2002/07/owl#equivalentProperty": [
      {
        "@id": "https://w3id.org/vibe-ontology/hasSubgenre"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Brand",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An identifiable commercial or institutional entity characterized by a name, identity, and set of associated meanings, values, and design practices, which can produce or influence artifacts, styles, and aesthetic associations."
      },
      {
        "@language": "it",
        "@value": "Un’entità commerciale o istituzionale identificabile caratterizzata da un nome, un’identità e un set di significati, valori e pratiche di design associate, che possono produrre o influenzare artefatti, stili e associazioni estetiche."
      },
      {
        "@language": "nl",
        "@value": "Een identificeerbare commerciële of institutionele entiteit die wordt gekenmerkt door een naam, identiteit en een reeks bijbehorende betekenissen, waarden en ontwerppraktijken, die artefacten, stijlen en esthetische associaties kan produceren of beïnvloeden."
      },
      {
        "@language": "ja",
        "@value": "名称、アイデンティティ、特有の価値観やデザイン指針によって識別される商業的・組織的実体。あらゆる品物やスタイルの創出、および美学との関連性の形成に影響を与える。"
      },
      {
        "@language": "ru",
        "@value": "Идентифицируемая коммерческая или общественная организация, характеризующаяся названием, идентичностью и набором смыслов, ценностей и практик дизайна, которая может создавать или влиять на артефакты, стили и эстетические ассоциации."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Brand"
      },
      {
        "@language": "it",
        "@value": "Marchio"
      },
      {
        "@language": "nl",
        "@value": "Merk"
      },
      {
        "@language": "ja",
        "@value": "ブランド"
      },
      {
        "@language": "ru",
        "@value": "Бренд"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Theme",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An abstract conceptual orientation or narrative underlying an aesthetic, capturing its dominant meanings, affective tone, or worldview. E.g., the theme of the Frutiger Aero aesthetic can be described as an optimistic, clean, and nature-integrated vision of the near future."
      },
      {
        "@language": "it",
        "@value": "Un orientamento concettuale astratto o una struttura narrativa sottostante a un’estetica, che ne cattura i significati dominanti, il tono affettivo o la visione del mondo. Ad esempio, il tema dell’estetica Frutiger Aero può essere descritto come una visione ottimistica, pulita e integrata con la natura del futuro prossimo."
      },
      {
        "@language": "nl",
        "@value": "Een abstracte conceptuele oriëntatie of narratief dat ten grondslag ligt aan een esthetiek en de dominante betekenissen, affectieve toon of wereldbeeld vastlegt. Bijv. het thema van de Frutiger Aero-esthetiek kan worden beschreven als een optimistische, schone en in de natuur geïntegreerde visie op de nabije toekomst."
      },
      {
        "@language": "ja",
        "@value": "美学の根底にある抽象的な概念的方向性またはナラティブ。主要な意味合い、感情的トーンや世界観を捉える。例：Frutiger Aeroの美学のテーマは、楽観的で清潔で自然と統合された近未来のビジョンであると表現できる。"
      },
      {
        "@language": "ru",
        "@value": "Абстрактная концептуальная направленность или нарратив, лежащий в основе эстетики и отражающий её доминирующие смыслы, эмоциональный тон или мировоззрение. Например, тему эстетики Frutiger Aero можно описать как оптимистичное, чистое и интегрированное с природой видение ближайшего будущего."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Tema"
      },
      {
        "@language": "en",
        "@value": "Theme"
      },
      {
        "@language": "nl",
        "@value": "Thema"
      },
      {
        "@language": "ja",
        "@value": "テーマ"
      },
      {
        "@language": "ru",
        "@value": "Тема"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/PeriodDefinition",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A temporally bounded but potentially imprecise interval used to situate entities or phenomena in time, allowing for vague or overlapping boundaries, in alignment with models such as PeriodO."
      },
      {
        "@language": "it",
        "@value": "Un intervallo temporale delimitato ma potenzialmente impreciso usato per collocare entità o fenomeni nel tempo, che consente di definire confini vaghi o con sovrapposizioni, allineato a modellazioni come PeriodO."
      },
      {
        "@language": "nl",
        "@value": "Een temporeel begrensd maar potentieel onvolledig interval dat wordt gebruikt om entiteiten of verschijnselen in de tijd te plaatsen, waarbij vage of overlappende grenzen mogelijk zijn, in overeenstemming met modellen zoals PeriodO."
      },
      {
        "@language": "ja",
        "@value": "実体や現象を時間軸上に位置づけるための時間的範囲。PeriodO等のモデルに準拠し、厳密な境界ではなく、曖昧さや期間の重複を許容する。"
      },
      {
        "@language": "ru",
        "@value": "Ограниченный во времени, но потенциально неточный интервал, используемый для локализации сущностей или явлений во времени; допускает размытые или пересекающиеся границы в соответствии с такими моделями, как PeriodO."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Definizione di periodo"
      },
      {
        "@language": "en",
        "@value": "Period Definition"
      },
      {
        "@language": "nl",
        "@value": "Periodedefinitie"
      },
      {
        "@language": "ja",
        "@value": "期間定義"
      },
      {
        "@language": "ru",
        "@value": "Определение периода"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "_:n10a9d9e078c44993be0b66527199cf7ab2"
      }
    ]
  },
  {
    "@id": "_:n10a9d9e078c44993be0b66527199cf7ab2",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#minCardinality": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger",
        "@value": "1"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "https://w3id.org/vibe-ontology/timeInterval"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasIconicFigure",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Associa un'Estetica a un Agente considerato suo rappresentante emblematico."
      },
      {
        "@language": "en",
        "@value": "Associates an Aesthetic with an Agent who is considered an emblematic or iconic representative of it."
      },
      {
        "@language": "nl",
        "@value": "Associeert een esthetiek met een agent die wordt beschouwd als een emblematische of iconische vertegenwoordiger ervan."
      },
      {
        "@language": "ja",
        "@value": "美学と、その象徴的または典型的な代表者と見なされるエージェントを関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Ассоциирует эстетику с агентом, который считается её каноничным или культовым представителем."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha figura iconica"
      },
      {
        "@language": "en",
        "@value": "has iconic figure"
      },
      {
        "@language": "nl",
        "@value": "heeft iconisch figuur"
      },
      {
        "@language": "ja",
        "@value": "象徴的人物"
      },
      {
        "@language": "ru",
        "@value": "имеет иконическую фигуру"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Agent"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2004/02/skos/core#Concept",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasLocation",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Associa qualsiasi entità a una collocazione spaziale, fisica o digitale."
      },
      {
        "@language": "en",
        "@value": "Associates any entity with a physical or digital spatial location."
      },
      {
        "@language": "nl",
        "@value": "Associeert elke entiteit met een fysieke of digitale ruimtelijke locatie."
      },
      {
        "@language": "ja",
        "@value": "任意のエンティティと物理的またはデジタルの空間的場所を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Ассоциирует любую сущность с физическим или цифровым пространственным расположением."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha luogo"
      },
      {
        "@language": "en",
        "@value": "has location"
      },
      {
        "@language": "nl",
        "@value": "heeft locatie"
      },
      {
        "@language": "ja",
        "@value": "所在地"
      },
      {
        "@language": "ru",
        "@value": "имеет местоположение"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
