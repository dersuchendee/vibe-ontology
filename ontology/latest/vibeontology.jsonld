      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Role",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role is a context-dependent function or qualification assigned to an entity within a relation."
      },
      {
        "@language": "it",
        "@value": "Un ruolo è una funzione o qualificazione dipendente dal contesto assegnata a un’entità all’interno di una relazione."
      },
      {
        "@language": "nl",
        "@value": "Een rol is een contextafhankelijke functie of kwalificatie die aan een entiteit binnen een relatie is toegewezen."
      },
      {
        "@language": "ja",
        "@value": "特定の関係性においてエンティティに割り当てられる、文脈依存の機能や属性。"
      },
      {
        "@language": "ru",
        "@value": "Роль — это зависящая от контекста функция или квалификация, присваиваемая сущности в рамках отношения."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Role"
      },
      {
        "@language": "it",
        "@value": "Ruolo"
      },
      {
        "@language": "nl",
        "@value": "Rol"
      },
      {
        "@language": "ja",
        "@value": "役割"
      },
      {
        "@language": "ru",
        "@value": "Роль"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/",
    "@type": [
      "http://www.w3.org/2002/07/owl#Ontology"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Ontologia per modellare le estetiche come categorie emergenti basate su collezioni e associazioni rappresentative."
      },
      {
        "@language": "en",
        "@value": "Ontology for modelling aesthetics as emergent, collection-based categories grounded in representative associations."
      },
      {
        "@language": "nl",
        "@value": "Ontologie voor het modelleren van esthetiek als emergente, op collecties gebaseerde categorieën die geworteld zijn in representatieve associaties."
      },
      {
        "@language": "ja",
        "@value": "美学とその象徴的な表象との結びつきを基盤とし、多様な要素のコレクションから立ち現れる美学的系統をモデル化するためのオントロジー。"
      },
      {
        "@language": "ru",
        "@value": "Онтология для моделирования эстетики как эмерджентных, коллекционно-обусловленных категорий, основанных на репрезентативных ассоциациях."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Ontologia Vibe"
      },
      {
        "@language": "en",
        "@value": "Vibe Ontology"
      },
      {
        "@language": "nl",
        "@value": "Vibe Ontologie"
      },
      {
        "@language": "ja",
        "@value": "Vibe オントロジー"
      },
      {
        "@language": "ru",
        "@value": "Вайб Онтология"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/valueDimension",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "dimensione del valore"
      },
      {
        "@language": "en",
        "@value": "value dimension"
      },
      {
        "@language": "nl",
        "@value": "waarde dimensie"
      },
      {
        "@language": "ja",
        "@value": "価値観の次元"
      },
      {
        "@language": "ru",
        "@value": "измерение ценности"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/FoodItem",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An edible item that may carry aesthetic or cultural significance."
      },
      {
        "@language": "it",
        "@value": "Un alimento che può avere rilevanza estetica o culturale."
      },
      {
        "@language": "nl",
        "@value": "Een eetbaar item dat esthetische of culturele betekenis kan hebben."
      },
      {
        "@language": "ja",
        "@value": "美的または文化的意義を持ちうる食用品。"
      },
      {
        "@language": "ru",
        "@value": "Пищевой продукт, который может иметь эстетическую или культурную значимость."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Alimento"
      },
      {
        "@language": "en",
        "@value": "Food Item"
      },
      {
        "@language": "nl",
        "@value": "Voedingsmiddel"
      },
      {
        "@language": "ja",
        "@value": "食品"
      },
      {
        "@language": "ru",
        "@value": "Продукт питания"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/TimeIndexedRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A contextual role assigned to an entity within a relation that is explicitly bound to a temporal interval, allowing the same entity to hold different roles at different times."
      },
      {
        "@language": "it",
        "@value": "Un ruolo assegnato a un’entità all’interno di una relazione, esplicitamente vincolato a un intervallo temporale, cosa che permette alla stessa entità di avere ruoli diversi in tempi diversi."
      },
      {
        "@language": "nl",
        "@value": "Een contextuele rol toegewezen aan een entiteit binnen een relatie die expliciet gebonden is aan een tijdsinterval, waardoor dezelfde entiteit op verschillende tijdstippen verschillende rollen kan vervullen."
      },
      {
        "@language": "ja",
        "@value": "時間区間に明示的に結びついた関係の中でエンティティに割り当てられる文脈的役割。同じエンティティが異なる時点で異なる役割を持つことを可能にする。"
      },
      {
        "@language": "ru",
        "@value": "Контекстная роль, присваиваемая сущности в рамках отношения, которое явно привязано к временному интервалу, что позволяет одной и той же сущности выполнять разные роли в разное время."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Ruolo indicizzato temporalmente"
      },
      {
        "@language": "en",
        "@value": "Time Indexed Role"
      },
      {
        "@language": "nl",
        "@value": "Tijdgeïndexeerde rol"
      },
      {
        "@language": "ja",
        "@value": "時間付き役割"
      },
      {
        "@language": "ru",
        "@value": "Временно обозначенная роль"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "_:n10a9d9e078c44993be0b66527199cf7ab3"
      },
