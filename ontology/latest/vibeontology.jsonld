        "@language": "en",
        "@value": "associated subculture"
      },
      {
        "@language": "it",
        "@value": "sottocultura associata"
      },
      {
        "@language": "nl",
        "@value": "geassocieerde subcultuur"
      },
      {
        "@language": "ja",
        "@value": "関連サブカルチャー"
      },
      {
        "@language": "ru",
        "@value": "ассоциированная субкультура"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Subculture"
      }
    ]
