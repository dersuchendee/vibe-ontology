  {
    "@id": "https://w3id.org/vibe-ontology/associatedSubculture",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega un'Estetica a una Sottocultura che le è socialmente associata o ha contribuito alla sua emergenza e stabilizzazione."
      },
      {
        "@language": "en",
        "@value": "Links an Aesthetic to a Subculture that is socially associated with it or contributed to its emergence and stabilization."
      },
      {
        "@language": "nl",
        "@value": "Koppelt een esthetiek aan een subcultuur die er sociaal mee geassocieerd is of heeft bijgedragen aan het ontstaan en de stabilisatie ervan."
      },
      {
        "@language": "ja",
        "@value": "美学と、社会的に関連の深いサブカルチャー、あるいはその出現や定着に寄与したサブカルチャーを結びつける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает эстетику с субкультурой, которая ассоциируется с ней в обществе или способствовала её возникновению и стабилизации."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
