    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Associa un'Estetica a un Valore che ne caratterizza l'orientamento."
      },
      {
        "@language": "en",
        "@value": "Associates an Aesthetic with an abstract Value that characterizes its orientation."
      },
      {
        "@language": "nl",
        "@value": "Associeert een esthetiek met een abstracte waarde die de oriëntatie ervan kenmerkt."
      },
      {
        "@language": "ja",
        "@value": "美学と、その方向性を特徴づける抽象的な価値観を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Ассоциирует эстетику с абстрактной ценностью, характеризующей её направленность."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
