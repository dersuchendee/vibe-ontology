  {
    "@id": "https://w3id.org/vibe-ontology/Video",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A moving-image artwork, typically digital."
      },
      {
        "@language": "it",
        "@value": "Un’opera audiovisiva, tipicamente digitale."
      },
      {
        "@language": "nl",
        "@value": "Een kunstwerk van bewegende beelden, meestal digitaal."
      },
      {
        "@language": "ja",
        "@value": "通常デジタルの動画作品。"
      },
      {
        "@language": "ru",
        "@value": "Произведение с движущимися изображениями, обычно цифровое."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Video"
      },
      {
        "@language": "it",
        "@value": "Video"
      },
      {
        "@language": "nl",
        "@value": "Video"
      },
      {
        "@language": "ja",
        "@value": "動画"
      },
      {
        "@language": "ru",
        "@value": "Видео"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Activity",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An action or practice carried out by individuals or groups, potentially associated with an aesthetic or subcultural context."
      },
      {
        "@language": "it",
        "@value": "Un’azione o pratica svolta da individui o gruppi, potenzialmente associata a un’estetica o a un contesto sottoculturale."
      },
      {
        "@language": "nl",
        "@value": "Een actie of praktijk uitgevoerd door individuen of groepen, mogelijk geassocieerd met een esthetische of subculturele context."
      },
      {
        "@language": "ja",
        "@value": "個人またはグループによって行われる行動または実践的活動。美学またはサブカルチャー的な文脈と結びついている場合がある。"
      },
      {
        "@language": "ru",
        "@value": "Индивидуальная или групповая деятельность или практика, потенциально ассоциируемая с эстетическим или субкультурным контекстом."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Activity"
      },
      {
        "@language": "it",
        "@value": "Attività"
      },
      {
        "@language": "nl",
        "@value": "Activiteit"
      },
      {
        "@language": "ja",
        "@value": "活動"
      },
      {
        "@language": "ru",
        "@value": "Активность"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/LiteraryWork",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A textual artwork such as a novel, poem, or written narrative."
      },
      {
        "@language": "it",
        "@value": "Un’opera testuale come romanzi, poesie o narrazioni scritte."
      },
      {
        "@language": "nl",
        "@value": "Een tekstueel kunstwerk zoals een roman, gedicht of geschreven verhaal."
      },
      {
        "@language": "ja",
        "@value": "小説、詩、書かれた物語などのテキスト作品。"
      },
      {
        "@language": "ru",
        "@value": "Текстовое произведение искусства, такое как роман, стихотворение или письменное повествование."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Literary Work"
      },
      {
        "@language": "it",
        "@value": "Opera letteraria"
      },
      {
        "@language": "nl",
        "@value": "Literair werk"
      },
      {
        "@language": "ja",
        "@value": "文学作品"
      },
      {
        "@language": "ru",
        "@value": "Литературное произведение"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Videogame",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An interactive digital artwork combining visual, narrative, and gameplay elements."
      },
      {
        "@language": "it",
        "@value": "Un’opera digitale interattiva che combina elementi visivi, narrativi e ludici."
      },
      {
        "@language": "nl",
        "@value": "Een interactief digitaal kunstwerk dat visuele, narratieve en gameplay-elementen combineert."
      },
      {
        "@language": "ja",
        "@value": "視覚的、物語的、ゲームプレイの要素を組み合わせたインタラクティブなデジタル作品。"
      },
      {
        "@language": "ru",
        "@value": "Интерактивное цифровое произведение, сочетающее визуальные, повествовательные и игровые элементы."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Videogame"
      },
      {
        "@language": "it",
        "@value": "Videogioco"
      },
      {
        "@language": "nl",
        "@value": "Videogame"
      },
      {
        "@language": "ja",
        "@value": "ビデオゲーム"
      },
      {
        "@language": "ru",
        "@value": "Видеоигра"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/associationDimension",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Classifica il tipo di associazione codificata da una RepresentativeAssociation. I valori attesi sono gli individui: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."
      },
      {
        "@language": "en",
        "@value": "Classifies the kind of association. Expected values are the named individuals: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."
      },
      {
        "@language": "nl",
        "@value": "Classificeert het type associatie gecodeerd door een RepresentativeAssociation. Verwachte waarden zijn de individuen: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."
      },
      {
        "@language": "ja",
        "@value": "関連性のレベルを分類するための属性。モチーフ、テーマ、価値観、色彩、プラットフォーム、音楽、ファッション、象徴的人物といった各次元を指定する。"
      },
      {
        "@language": "ru",
        "@value": "Классифицирует тип ассоциации. Ожидаемые значения — индивиды: измерение мотива (motifDimension), темы (themeDimension), ценности (valueDimension), цвета (colorDimension), платформы (platformDimension), музыки (musicDimension), моды (fashionDimension) или иконической фигуры (iconicFigureDimension)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/RepresentativeAssociation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "association dimension"
      },
      {
        "@language": "it",
        "@value": "dimensione dell’associazione"
      },
      {
        "@language": "nl",
        "@value": "associatie dimensie"
      },
      {
        "@language": "ja",
        "@value": "関連の次元"
      },
      {
        "@language": "ru",
        "@value": "измерение ассоциации"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2004/02/skos/core#broader",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/withRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Specifica il Ruolo ricoperto dall'entità all'interno di una relazione di tipo Ruolo indicizzato temporalmente."
      },
      {
        "@language": "en",
        "@value": "Specifies the Role held by the entity within a TimeIndexedRole relation."
      },
      {
        "@language": "nl",
        "@value": "Specificeert de rol die de entiteit vervult binnen een tijdgeïndexeerde rolrelatie."
      },
      {
        "@language": "ja",
        "@value": "特定の関係性や時間的な枠組みにおいて、エンティティが担っている具体的な役割を示す。"
      },
      {
        "@language": "ru",
        "@value": "Определяет Роль, которую сущность играет в рамках отношения временной роли (TimeIndexedRole)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/TimeIndexedRole"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "con ruolo"
      },
      {
        "@language": "en",
        "@value": "with role"
      },
      {
        "@language": "nl",
        "@value": "met rol"
      },
      {
        "@language": "ja",
        "@value": "役割"
      },
      {
        "@language": "ru",
        "@value": "с ролью"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Role"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Artwork",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A creative artifact produced within any expressive medium, including visual (images, paintings, sculpture, architecture, film, videogames), auditory (music), textual (literature), or embodied/industrial forms (fashion). It is treated as a generic work entity independent of medium-specific taxonomies."
      },
      {
        "@language": "it",
        "@value": "Un artefatto creativo prodotto in qualsiasi mezzo espressivo, inclusi visivo (immagini, dipinti, sculture, architetture, film, videogiochi), sonoro (musica), testuale (letteratura) o forme industriali come la moda. Viene trattato come un'opera indipendente dalle tassonomie relative ai media."
      },
      {
        "@language": "nl",
        "@value": "Een creatief artefact geproduceerd binnen elk expressief medium, inclusief visueel (afbeeldingen, schilderijen, beeldhouwwerk, architectuur, film, videogames), auditief (muziek), tekstueel (literatuur) of belichaamde/industriële vormen (mode). Het wordt behandeld als een generieke werkentiteit, onafhankelijk van medium-specifieke taxonomieën."
      },
      {
        "@language": "ja",
        "@value": "視覚（画像、絵画、彫刻、建築、映画、ビデオゲーム）、聴覚（音楽）、テキスト（文学）、または身体的・産業的形態（ファッション）を含む、あらゆる表現メディアで制作された創造的成果物。メディア特有の分類に依存しない汎用的な作品エンティティとして扱われる。"
      },
      {
        "@language": "ru",
        "@value": "Творческий артефакт, созданный в любой выразительной среде, включая визуальную (изображения, живопись, скульптура, архитектура, кино, видеоигры), звуковую (музыка), текстовую (литература) или воплощенные/индустриальные формы (мода). Рассматривается как общая сущность произведения, независимая от классификаций конкретных медиа."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Artwork"
      },
      {
        "@language": "it",
        "@value": "Opera d'arte"
      },
      {
        "@language": "nl",
        "@value": "Kunstwerk"
      },
      {
        "@language": "ja",
        "@value": "作品"
      },
      {
        "@language": "ru",
        "@value": "Произведение искусства"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasPrimaryPlatform",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Specifica la Piattaforma principale attraverso cui un'Estetica è prevalentemente diffusa o ha acquisito visibilità."
      },
      {
        "@language": "en",
        "@value": "Specifies the main Platform through which an Aesthetic is primarily disseminated or has gained visibility."
      },
      {
        "@language": "nl",
        "@value": "Specificeert het belangrijkste platform waarlangs een esthetiek voornamelijk wordt verspreid of zichtbaarheid heeft verkregen."
      },
      {
        "@language": "ja",
        "@value": "美学が主に普及、または認知を得た主要なプラットフォームを指定する。"
      },
      {
        "@language": "ru",
        "@value": "Указывает на основную платформу, через которую эстетика преимущественно распространялась или получила известность."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha piattaforma principale"
      },
      {
        "@language": "en",
        "@value": "has primary platform"
      },
      {
        "@language": "nl",
        "@value": "heeft primair platform"
      },
      {
        "@language": "ja",
        "@value": "主要プラットフォーム"
      },
      {
        "@language": "ru",
        "@value": "имеет основную платформу"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Platform"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/hasPlatform"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/name",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "name"
      },
      {
        "@language": "it",
        "@value": "nome"
      },
      {
        "@language": "nl",
        "@value": "naam"
      },
      {
        "@language": "ja",
        "@value": "名称"
      },
      {
        "@language": "ru",
        "@value": "название"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Fashion",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A domain of embodied and material expression involving clothing, styling, and adornment practices, through which cultural meanings, identities, and aesthetic orientations are communicated."
      },
      {
        "@language": "it",
        "@value": "Un ambito di espressione materiale che coinvolge abbigliamento e pratiche di stile, attraverso cui si comunicano significati culturali, identità e orientamenti estetici."
      },
      {
        "@language": "nl",
        "@value": "Een domein van belichaamde en materiële expressie met betrekking tot kleding, styling en versieringspraktijken, waardoor culturele betekenissen, identiteiten en esthetische oriëntaties worden gecommuniceerd."
      },
      {
        "@language": "ja",
        "@value": "衣服、スタイリング、装飾といった身体的・物質的な表現領域。文化的な意味合いやアイデンティティ、美的方向性を伝達する手段として機能する。"
      },
      {
        "@language": "ru",
        "@value": "Сфера телесного и материального самовыражения, включающая одежду, стайлинг и практики украшения тела, посредством которых транслируются культурные смыслы, идентичности и эстетические ориентиры."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Fashion"
      },
      {
        "@language": "it",
        "@value": "Moda"
      },
      {
        "@language": "nl",
        "@value": "Mode"
      },
      {
        "@language": "ja",
        "@value": "ファッション"
      },
      {
        "@language": "ru",
        "@value": "Мода"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/MusicWork",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An artwork expressed through sound and musical composition."
      },
      {
        "@language": "it",
        "@value": "Un’opera espressa attraverso il suono e la composizione musicale."
      },
      {
        "@language": "nl",
        "@value": "Een kunstwerk uitgedrukt via geluid en muzikale compositie."
      },
      {
        "@language": "ja",
        "@value": "音と音楽的構成を通じて表現される作品。"
      },
      {
        "@language": "ru",
        "@value": "Произведение искусства, выраженное через звук и музыкальную композицию."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Music Work"
      },
      {
        "@language": "it",
        "@value": "Opera musicale"
      },
      {
        "@language": "nl",
        "@value": "Muzikaal werk"
      },
      {
        "@language": "ja",
        "@value": "音楽作品"
      },
      {
        "@language": "ru",
        "@value": "Музыкальное произведение"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/IconicFigure",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role representing an individual strongly associated with an aesthetic."
      },
      {
        "@language": "it",
        "@value": "Un ruolo che rappresenta un individuo fortemente associato a un’estetica."
      },
      {
        "@language": "nl",
        "@value": "Een rol die een individu vertegenwoordigt dat sterk geassocieerd wordt met een esthetiek."
      },
      {
        "@language": "ja",
        "@value": "美学と強く関連する個人を表す役割。"
      },
      {
        "@language": "ru",
        "@value": "Роль, представляющая личность, тесно связанную с определенной эстетикой."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Figura iconica"
      },
      {
        "@language": "en",
        "@value": "Iconic Figure"
      },
      {
        "@language": "nl",
        "@value": "Iconisch figuur"
      },
      {
        "@language": "ja",
        "@value": "象徴的人物"
      },
      {
        "@language": "ru",
        "@value": "Иконическая фигура"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Role"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Album",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A music work consisting of a collection of recorded tracks released as a single unit."
      },
      {
        "@language": "it",
        "@value": "Un’opera musicale composta da una raccolta di tracce pubblicate come un’unica unità."
      },
      {
        "@language": "nl",
        "@value": "Een muzikaal werk bestaande uit een verzameling opgenomen tracks die als één geheel zijn uitgebracht."
      },
      {
        "@language": "ja",
        "@value": "一つの単位としてリリースされた録音トラックのコレクションからなる音楽作品。"
      },
      {
        "@language": "ru",
        "@value": "Музыкальное произведение, состоящее из коллекции записанных треков, выпущенных единым изданием."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Album"
      },
      {
        "@language": "it",
        "@value": "Album"
      },
      {
        "@language": "nl",
        "@value": "Album"
      },
      {
        "@language": "ja",
        "@value": "アルバム"
      },
      {
        "@language": "ru",
        "@value": "Альбом"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/MusicWork"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/overlapsWith",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty",
      "http://www.w3.org/2002/07/owl#SymmetricProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Indica che due Estetiche condividono elementi o associazioni significativi, senza che l'una sia sottogenere dell'altra. Questa proprietà è simmetrica."
      },
      {
        "@language": "en",
        "@value": "Indicates that two Aesthetics share significant elements or associations without either being a subgenre of the other. This property is symmetric."
      },
      {
        "@language": "nl",
        "@value": "Geeft aan dat twee esthetieken significante elementen of associaties delen, zonder dat de een een subgenre van de ander is. Deze eigenschap is symmetrisch."
      },
      {
        "@language": "ja",
        "@value": "二つの美学が、どちらも相手のサブジャンルではなく、重要な要素や関連を共有することを示す。この性質は対称的である。"
      },
      {
        "@language": "ru",
        "@value": "Указывает на то, что две эстетики имеют общие значимые элементы или ассоциации, при этом ни одна не является поджанром другой. Свойство симметрично."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "overlaps with"
      },
      {
        "@language": "it",
        "@value": "si sovrappone a"
      },
      {
        "@language": "nl",
        "@value": "overlapt met"
      },
      {
        "@language": "ja",
        "@value": "重複する"
      },
      {
        "@language": "ru",
        "@value": "пересекается с"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/relatedTo"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasSubgenre",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega un'Estetica a un'Estetica più specifica che ne costituisce una sottovariante."
      },
      {
        "@language": "en",
        "@value": "Relates an Aesthetic to a more specific Aesthetic that constitutes one of its subvariants."
      },
      {
        "@language": "nl",
        "@value": "Verbindt een esthetiek met een specifiekere esthetiek die er een subvariant van vormt."
      },
      {
        "@language": "ja",
        "@value": "美学と、その派生系統を構成する、より具体的な美学を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает Эстетику с более узкой Эстетикой, являющейся её подвариантом."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha sottogenere"
      },
      {
        "@language": "en",
        "@value": "has subgenre"
      },
      {
        "@language": "nl",
        "@value": "heeft subgenre"
      },
      {
        "@language": "ja",
        "@value": "サブジャンル"
      },
      {
        "@language": "ru",
        "@value": "имеет поджанр"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/relatedTo"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/isSubgenreOf"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/coinedBy",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega un'Estetica all'Agente che l'ha coniata o che vi ha dato il nome per la prima volta."
      },
      {
        "@language": "en",
        "@value": "Relates an Aesthetic to the Agent who coined or first named it."
      },
      {
        "@language": "nl",
        "@value": "Verbindt een esthetiek met de agent die deze heeft opgebracht of voor het eerst een naam heeft gegeven."
      },
      {
        "@language": "ja",
        "@value": "美学と、それを作り出したまたは最初に名付けたエージェントを関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает эстетику с агентом, который впервые ввел её название или термин."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "coined by"
      },
      {
        "@language": "it",
        "@value": "coniato da"
      },
      {
        "@language": "nl",
        "@value": "opgebracht door"
      },
      {
        "@language": "ja",
        "@value": "命名者"
      },
      {
        "@language": "ru",
        "@value": "придумано (кем)"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Agent"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Agent",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An entity capable of acting, creating, or influencing cultural artifacts or aesthetics, including individuals and groups."
      },
      {
        "@language": "it",
        "@value": "Un’entità capace di agire, creare o influenzare artefatti culturali o estetiche, inclusi individui e gruppi."
      },
      {
        "@language": "nl",
        "@value": "Een entiteit die in staat is tot handelen, creëren of het beïnvloeden van culturele artefacten of esthetiek, inclusief individuen en groepen."
      },
      {
        "@language": "ja",
        "@value": "個人やグループを含む、文化的成果物や美学に対して行動、創造、影響を与える能力を持つエンティティ。"
      },
      {
        "@language": "ru",
        "@value": "Сущность, способная действовать, создавать или влиять на культурные артефакты или эстетику, включая индивидов и группы."
      },
      {
        "@language": "ru",
        "@value": "Агент"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Agent"
      },
      {
        "@language": "it",
        "@value": "Agente"
      },
      {
        "@language": "nl",
        "@value": "Actor"
      },
      {
        "@language": "ja",
        "@value": "エージェント"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/TimeInterval",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A temporal extent with a start and/or end that may be precisely defined or approximate, used to qualify the temporal validity of entities, roles, or associations."
      },
      {
        "@language": "it",
        "@value": "Un’estensione temporale con un inizio e/o una fine, che può essere precisa o approssimata, usata per qualificare la validità temporale di entità, ruoli o associazioni."
      },
      {
        "@language": "nl",
        "@value": "Een temporele omvang met een begin en/of einde dat nauwkeurig gedefinieerd of bij benadering kan zijn, gebruikt om de temporele geldigheid van entiteiten, rollen of associaties te kwalificeren."
      },
      {
        "@language": "ja",
        "@value": "エンティティ、役割、あるいは関連性の時間的な有効範囲を定義するための期間。厳密な開始・終了時期は、近似的な範囲も許容する。"
      },
      {
        "@language": "ru",
        "@value": "Временной отрезок с началом и/или концом, который может быть точно определенным или приблизительным; используется для квалификации временной валидности сущностей, ролей или ассоциаций."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Intervallo temporale"
      },
      {
        "@language": "en",
        "@value": "Time Interval"
      },
      {
        "@language": "nl",
        "@value": "Tijdsinterval"
      },
      {
        "@language": "ja",
        "@value": "時間区間"
      },
      {
        "@language": "ru",
        "@value": "Временной интервал"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/timeInterval",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega una PeriodDefinition all'intervallo temporale che essa definisce."
      },
      {
        "@language": "en",
        "@value": "Links a PeriodDefinition to the TimeInterval it defines."
      },
      {
        "@language": "nl",
        "@value": "Koppelt een periodedefinitie aan het tijdsinterval dat het definieert."
      },
      {
        "@language": "ja",
        "@value": "期間定義と、それが定義する時間区間を結びつける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает определение периода с временным интервалом, который оно описывает."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/PeriodDefinition"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "intervallo temporale"
      },
      {
        "@language": "en",
        "@value": "time interval"
      },
      {
        "@language": "nl",
        "@value": "tijdsinterval"
      },
      {
        "@language": "ja",
        "@value": "時間区間"
      },
      {
        "@language": "ru",
        "@value": "временной интервал"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/TimeInterval"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Person",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An individual human agent."
      },
      {
        "@language": "it",
        "@value": "Un individuo umano."
      },
      {
        "@language": "nl",
        "@value": "Een individuele menselijke actor."
      },
      {
        "@language": "ja",
        "@value": "個々の人間エージェント。"
      },
      {
        "@language": "ru",
        "@value": "Человеческий индивид."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Person"
      },
      {
        "@language": "it",
        "@value": "Persona"
      },
      {
        "@language": "nl",
        "@value": "Persoon"
      },
      {
        "@language": "ja",
        "@value": "人物"
      },
      {
        "@language": "ru",
        "@value": "Персона"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Agent"
      }
    ],
    "http://www.w3.org/2002/07/owl#disjointWith": [
      {
        "@id": "https://w3id.org/vibe-ontology/Platform"
      },
      {
        "@id": "https://w3id.org/vibe-ontology/TimeInterval"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/themeDimension",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "dimensione del tema"
      },
      {
        "@language": "en",
        "@value": "theme dimension"
      },
      {
        "@language": "nl",
        "@value": "thematische dimensie"
      },
      {
        "@language": "ja",
        "@value": "テーマの次元"
      },
      {
        "@language": "ru",
        "@value": "измерение темы"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Motif",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A recurrent and recognizable element (visual, conceptual, or stylistic) that contributes to the identity of an aesthetic through repeated association. E.g., the Frutiger Aero aesthetic’s motifs include skeuomorphism, glossy textures, bubbles, nature imagery, and Frutiger-type fonts."
      },
      {
        "@language": "it",
        "@value": "Un elemento ricorrente e riconoscibile (di tipo visivo, concettuale o stilistico) che contribuisce all’identità di un’estetica attraverso associazioni ripetute. Per esempio, nell’estetica Frutiger Aero, i motivi includono scheumorfismo, texture lucide, scene di natura e font di tipo Frutiger."
      },
      {
        "@language": "nl",
        "@value": "Een terugkerend en herkenbaar element (visueel, conceptueel of stilistisch) dat bijdraagt aan de identiteit van een esthetiek door herhaalde associatie. Bijv. de motieven van de Frutiger Aero-esthetiek omvatten skeuomorfisme, glanzende texturen, bubbels, natuurbeelden en Frutiger-type lettertypen."
      },
      {
        "@language": "ja",
        "@value": "美学のアイデンティティ形成に寄与する、特徴的な要素（視覚、概念、スタイル）。繰り返しその美学との関連性として現れる。　例：Frutiger Aeroにおける光沢感、泡、自然のイメージ、Frutiger系フォントなど。"
      },
      {
        "@language": "ru",
        "@value": "Повторяющийся и узнаваемый элемент (визуальный, концептуальный или стилистический), который формирует идентичность эстетики через многократные ассоциации. Например, мотивы эстетики Frutiger Aero включают скевоморфизм, глянцевые текстуры, пузырьки, образы природы и шрифты семейства Frutiger."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Motif"
      },
      {
        "@language": "it",
        "@value": "Motivo"
      },
      {
        "@language": "nl",
        "@value": "Motief"
      },
      {
        "@language": "ja",
        "@value": "モチーフ"
      },
      {
        "@language": "ru",
        "@value": "Мотив"
      }
    ]
  }
]