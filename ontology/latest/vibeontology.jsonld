      },
      {
        "@language": "nl",
        "@value": "muzikale dimensie"
      },
      {
        "@language": "ja",
        "@value": "音楽の次元"
      },
      {
        "@language": "ru",
        "@value": "музыкальное измерение"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/isSubgenreOf",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega un'Estetica a un'Estetica più ampia di cui essa è una sottovariante più specifica."
      },
      {
        "@language": "en",
        "@value": "Relates an Aesthetic to a broader Aesthetic of which it is a more specific subvariant."
      },
      {
        "@language": "nl",
        "@value": "Verbindt een esthetiek met een bredere esthetiek waarvan het een specifiekere subvariant is."
      },
      {
        "@language": "ja",
        "@value": "美学と、それが属する上位ジャンル、親ジャンル（より広い美学）を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает эстетику с более широкой эстетикой, подвариантом которой она является."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "is subgenre of"
      },
      {
        "@language": "it",
        "@value": "è sottogenere di"
      },
      {
        "@language": "nl",
        "@value": "is subgenre van"
      },
      {
        "@language": "ja",
        "@value": "上位ジャンル"
      },
      {
        "@language": "ru",
        "@value": "является поджанром"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/relatedTo"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Painting",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A visual artwork created using paint on a surface."
      },
      {
        "@language": "it",
        "@value": "Un’opera visiva realizzata con pittura su una superficie."
      },
      {
        "@language": "nl",
        "@value": "Een visueel kunstwerk gemaakt met verf op een oppervlak."
      },
      {
        "@language": "ja",
        "@value": "表面に絵の具を使って制作された視覚的作品。"
      },
      {
        "@language": "ru",
        "@value": "Визуальное произведение искусства, созданное красками на какой-либо поверхности."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Dipinto"
      },
      {
        "@language": "en",
        "@value": "Painting"
      },
      {
        "@language": "nl",
        "@value": "Schilderij"
      },
      {
        "@language": "ja",
        "@value": "絵画"
      },
      {
        "@language": "ru",
        "@value": "Картина"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/DigitalPlace",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A virtual environment where interactions, content creation, or community practices occur (e.g., forums, websites, social networks)."
      },
      {
        "@language": "it",
        "@value": "Un ambiente virtuale in cui avvengono interazioni, creazione di contenuti o pratiche comunitarie (per esempio, forum, siti web, social network)."
      },
      {
        "@language": "nl",
        "@value": "Een virtuele omgeving waar interacties, contentcreatie of gemeenschapspraktijken plaatsvinden (bijv. forums, websites, sociale netwerken)."
      },
      {
        "@language": "ja",
        "@value": "ユーザー同士の交流、コンテンツの制作や発信、コミュニティ活動等が行われるデジタル上の空間やプラットフォーム（例：SNS、掲示板、フォーラム、ウェブサイト等）。"
      },
      {
        "@language": "ru",
        "@value": "Виртуальная среда, где происходит взаимодействие, создание контента или практики сообщества (например, форумы, веб-сайты, социальные сети)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Digital Place"
      },
      {
        "@language": "it",
        "@value": "Luogo digitale"
      },
      {
        "@language": "nl",
        "@value": "Digitale plek"
      },
      {
        "@language": "ja",
        "@value": "デジタル空間"
      },
      {
        "@language": "ru",
        "@value": "Цифровое пространство"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Location"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasPeriodDefinition",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Associa un'entità a una Definizione di periodo che la colloca in un contesto temporale."
      },
      {
        "@language": "en",
        "@value": "Associates an entity with a PeriodDefinition that situates it within a temporal context."
      },
      {
        "@language": "nl",
        "@value": "Associeert een entiteit met een periodedefinitie die deze binnen een temporele context plaatst."
      },
      {
        "@language": "ja",
        "@value": "エンティティと、それを時間的文脈に位置づける期間定義を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Ассоциирует сущность с Определением периода, помещая её в конкретный временной контекст."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha definizione di periodo"
      },
      {
        "@language": "en",
        "@value": "has period definition"
      },
      {
        "@language": "nl",
        "@value": "heeft periodedefinitie"
      },
      {
        "@language": "ja",
        "@value": "期間定義"
      },
      {
        "@language": "ru",
        "@value": "имеет определение периода"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/PeriodDefinition"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/precedes",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty",
      "http://www.w3.org/2002/07/owl#TransitiveProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Indica che un'Estetica precede temporalmente o stilisticamente un'altra. Questa proprietà è transitiva."
      },
      {
        "@language": "en",
        "@value": "Indicates that one Aesthetic temporally or stylistically precedes another. This property is transitive."
      },
      {
        "@language": "nl",
        "@value": "Geeft aan dat een esthetiek een andere temporeel of stylistisch voorafgaat. Deze eigenschap is transitief."
      },
      {
        "@language": "ja",
        "@value": "ある美学が別の美学に時間的またはスタイル的に先行することを示す。この性質は推移的である。"
      },
      {
        "@language": "ru",
        "@value": "Указывает на то, что одна эстетика предшествует другой во времени или стилистически. Свойство транзитивно."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "precede"
      },
      {
        "@language": "en",
        "@value": "precedes"
      },
      {
        "@language": "nl",
        "@value": "gaat vooraf aan"
      },
      {
        "@language": "ja",
        "@value": "先行する"
      },
      {
        "@language": "ru",
        "@value": "предшествует"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasTheme",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Associa un'Opera a un Tema che esprime, veicola o mette in primo piano."
      },
      {
        "@language": "en",
        "@value": "Associates an Artwork with a Theme it conveys, expresses, or foregrounds."
      },
      {
        "@language": "nl",
        "@value": "Associeert een werk met een thema dat het uitdrukt, uitdraagt of op de voorgrond plaatst."
      },
      {
        "@language": "ja",
        "@value": "作品とそのテーマ（作品が伝え、表現し、または強調している主旨やトーン）を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Ассоциирует произведение с темой, которую оно выражает или выдвигает на первый план."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha tema"
      },
      {
        "@language": "en",
        "@value": "has theme"
      },
      {
        "@language": "nl",
        "@value": "heeft thema"
      },
      {
        "@language": "ja",
        "@value": "テーマ"
      },
      {
        "@language": "ru",
        "@value": "имеет тему"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Theme"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Value",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "An abstract principle, an affective/axiological orientation, or evaluative dimension (ethical, cultural, aesthetic, or ideological) associated with entities or aesthetics. Values are not limited to moral judgments but include broader attitudinal or conceptual stances. E.g., the aesthetic Frutiger Aero is associated with optimism, cleanliness, techno-natural harmony."
      },
      {
        "@language": "it",
        "@value": "Un principio astratto, un orientamento affettivo/assiologico o una dimensione valutativa (etica, culturale, estetica o ideologica) associata a entità o estetiche. I valori non si limitano ai giudizi morali, ma includono anche atteggiamenti e posizioni concettuali più ampie. Ad esempio, l’estetica Frutiger Aero è associata a ottimismo, pulizia e armonia tecno-naturale."
      },
      {
        "@language": "nl",
        "@value": "Een abstract principe, een affectieve/axiologische oriëntatie of evaluatieve dimensie (ethisch, cultureel, esthetisch of ideologisch) geassocieerd met entiteiten of esthetiek. Waarden zijn niet beperkt tot morele oordelen, maar omvatten bredere houdings- of conceptuele standpunten. Bijv. de esthetiek Frutiger Aero wordt geassocieerd met optimisme, netheid en techno-natuurlijke harmonie."
      },
      {
        "@language": "ja",
        "@value": "エンティティや美学に関連する抽象的な原理、感情的・価値論的方向性、または評価的次元（倫理的、文化的、美的、またはイデオロギー的）。道徳的判断にのみならず、より広い態度や概念的なスタンスを含む。。例：Frutiger Aeroの美学は楽観主義、清潔さ、テクノ的自然調和といった価値観と関連している。"
      },
      {
        "@language": "ru",
        "@value": "Абстрактный принцип, аффективная/аксиологическая направленность или оценочное измерение (этическое, культурное, эстетическое или идеологическое), связанное с сущностями или эстетиками. Ценности не ограничиваются моральными суждениями, а включают широкие мировоззренческие или концептуальные позиции. Например, эстетика Frutiger Aero ассоциируется с оптимизмом, чистотой и техно-природной гармонией."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Valore"
      },
      {
        "@language": "en",
        "@value": "Value"
      },
      {
        "@language": "nl",
        "@value": "Waarde"
      },
      {
        "@language": "ja",
        "@value": "価値観"
      },
      {
        "@language": "ru",
        "@value": "Ценность"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasColorPalette",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Associates an Aesthetic with a characteristic ColorPalette that contributes to its visual identity."
      },
      {
        "@language": "it",
        "@value": "Associa un'Estetica a una palette di colori caratteristica che contribuisce alla sua identità visiva."
      },
      {
        "@language": "nl",
        "@value": "Associeert een esthetiek met een karakteristiek kleurenpalet dat bijdraagt aan de visuele identiteit."
      },
      {
        "@language": "ja",
        "@value": "美学と、その視覚的アイデンティティに寄与する特徴的なカラーパレットを関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Ассоциирует эстетику с характерной цветовой палитрой, определяющей её визуальную идентичность."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha palette di colori"
      },
      {
        "@language": "en",
        "@value": "has color palette"
      },
      {
        "@language": "nl",
        "@value": "heeft kleurenpalet"
      },
      {
        "@language": "ja",
        "@value": "カラーパレット"
      },
      {
        "@language": "ru",
        "@value": "имеет цветовую палитру"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/ColorPalette"
      }
    ]
  },
