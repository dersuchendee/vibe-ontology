        "@language": "it",
        "@value": "Associa un'Estetica a una Piattaforma su cui essa circola o è stata diffusa."
      },
      {
        "@language": "en",
        "@value": "Associates an Aesthetic with a Platform on which it circulates or has been disseminated."
      },
      {
        "@language": "nl",
        "@value": "Associeert een esthetiek met een platform waarop deze circuleert of is verspreid."
      },
      {
        "@language": "ja",
        "@value": "美学と、それが流通しまたは普及したプラットフォームを関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Ассоциирует эстетику с платформой, на которой она распространяется."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
