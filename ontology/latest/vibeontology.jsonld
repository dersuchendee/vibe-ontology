  {
    "@id": "https://w3id.org/vibe-ontology/Song",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A single musical composition, typically consisting of lyrics and melody."
      },
      {
        "@language": "it",
        "@value": "Una composizione musicale singola, tipicamente composta da testo e melodia."
      },
      {
        "@language": "nl",
        "@value": "Een enkele muzikale compositie, meestal bestaande uit tekst en melodie."
      },
      {
        "@language": "ja",
        "@value": "通常、歌詞とメロディーからなる単一の音楽的構成。"
      },
      {
        "@language": "ru",
        "@value": "Отдельное музыкальное произведение, обычно состоящее из слов и мелодии."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Canzone"
      },
      {
        "@language": "en",
        "@value": "Song"
      },
      {
        "@language": "nl",
        "@value": "Lied"
      },
      {
        "@language": "ja",
        "@value": "楽曲"
      },
      {
        "@language": "ru",
        "@value": "Песня"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
