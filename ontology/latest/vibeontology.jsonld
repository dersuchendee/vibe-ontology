  {
    "@id": "https://w3id.org/vibe-ontology/Group",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A collection of agents acting or identified as a unit."
      },
      {
        "@language": "it",
        "@value": "Un insieme di agenti che agiscono o sono identificati come un’unità."
      },
      {
        "@language": "nl",
        "@value": "Een verzameling actoren die handelen of worden geïdentificeerd als een eenheid."
      },
      {
        "@language": "ja",
        "@value": "一つの単位として行動または識別されるエージェントの集合。"
      },
      {
        "@language": "ru",
        "@value": "Объединение агентов, действующих или определяемых как единое целое."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Group"
      },
      {
        "@language": "it",
        "@value": "Gruppo"
      },
      {
        "@language": "nl",
        "@value": "Groep"
      },
      {
        "@language": "ja",
        "@value": "グループ"
      },
      {
        "@language": "ru",
        "@value": "Группа"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Agent"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2004/02/skos/core#closeMatch",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/influencedBy",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega un'Estetica a un'altra Estetica da cui essa ha tratto influenza stilistica, tematica o culturale."
      },
      {
        "@language": "en",
        "@value": "Relates an Aesthetic to another Aesthetic from which it has drawn stylistic, thematic, or cultural influence."
      },
      {
        "@language": "nl",
        "@value": "Verbindt een esthetiek met een andere esthetiek waarvan het stilistische, thematische of culturele invloed heeft ondergaan."
      },
      {
        "@language": "ja",
        "@value": "美学と、それがスタイル的、テーマ的、または文化的影響を受けた別の美学を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает эстетику с другой эстетикой, которая послужила источником стилистического, тематического или культурного влияния."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "influenced by"
      },
      {
        "@language": "it",
        "@value": "influenzato da"
      },
      {
        "@language": "nl",
        "@value": "beïnvloed door"
      },
      {
        "@language": "ja",
        "@value": "影響を受けた"
      },
      {
        "@language": "ru",
        "@value": "находится под влиянием"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/relatedTo"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Image",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A visual artwork such as a photograph or digital image."
      },
      {
        "@language": "it",
        "@value": "Un’opera visiva come una fotografia o immagine digitale."
      },
      {
        "@language": "nl",
        "@value": "Een visueel kunstwerk zoals een foto of digitale afbeelding."
      },
      {
        "@language": "ja",
        "@value": "写真やデジタル画像などの視覚的作品。"
      },
      {
        "@language": "ru",
        "@value": "Визуальное произведение искусства, такое как фотография или цифровое изображение."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Image"
      },
      {
        "@language": "it",
        "@value": "Immagine"
      },
      {
        "@language": "nl",
        "@value": "Afbeelding"
      },
      {
        "@language": "ja",
        "@value": "画像"
      },
      {
        "@language": "ru",
        "@value": "Изображение"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ]
  },
  {
    "@id": "http://www.w3.org/2004/02/skos/core#prefLabel",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://www.w3.org/2002/07/owl#equivalentProperty": [
      {
        "@id": "https://w3id.org/vibe-ontology/name"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/forAesthetic",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega una AssociazioneRappresentativa all'Estetica che essa qualifica."
      },
      {
        "@language": "en",
        "@value": "Links a RepresentativeAssociation to the Aesthetic it qualifies."
      },
      {
        "@language": "nl",
        "@value": "Koppelt een RepresentativeAssociation aan de esthetiek die het kwalificeert."
      },
      {
        "@language": "ja",
        "@value": "象徴的な関連（Representative Association）が、どの美学的系統を規定・説明しているかを示す。"
      },
      {
        "@language": "ru",
        "@value": "Связывает репрезентативную ассоциацию с конкретной эстетикой, которую она характеризует."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/RepresentativeAssociation"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "for aesthetic"
      },
      {
        "@language": "it",
        "@value": "per estetica"
      },
      {
        "@language": "nl",
        "@value": "voor esthetiek"
      },
      {
        "@language": "ja",
        "@value": "対象"
      },
      {
        "@language": "ru",
        "@value": "для эстетики"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Color",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A visual attribute perceived through light, often contributing to aesthetic identity."
      },
      {
        "@language": "it",
        "@value": "Un attributo visivo percepito attraverso la luce, che contribuisce all’identità estetica."
      },
      {
        "@language": "nl",
        "@value": "Een visueel kenmerk waargenomen door licht, dat vaak bijdraagt aan esthetische identiteit."
      },
      {
        "@language": "ja",
        "@value": "光を通じて知覚される視覚的属性。美的アイデンティティに貢献することが多い。"
      },
      {
        "@language": "ru",
        "@value": "Визуальный атрибут, воспринимаемый через свет, часто вносящий вклад в эстетическую идентичность."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Color"
      },
      {
        "@language": "it",
        "@value": "Colore"
      },
      {
        "@language": "nl",
        "@value": "Kleur"
      },
      {
        "@language": "ja",
        "@value": "色"
      },
      {
        "@language": "ru",
        "@value": "Цвет"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Anime",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A form of animated artwork originating primarily from Japanese media contexts."
      },
      {
        "@language": "it",
        "@value": "Una forma di opera animata originaria principalmente del contesto mediatico giapponese."
      },
      {
        "@language": "nl",
        "@value": "Een vorm van geanimeerd kunstwerk die voornamelijk voortkomt uit Japanse mediacontexten."
      },
      {
        "@language": "ja",
        "@value": "主に日本のメディア文脈から生まれたアニメーション作品の形態。"
      },
      {
        "@language": "ru",
        "@value": "Форма анимационного искусства, зародившаяся преимущественно в контексте японских медиа."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Anime"
      },
      {
        "@language": "it",
        "@value": "Anime"
      },
      {
        "@language": "nl",
        "@value": "Anime"
      },
      {
        "@language": "ja",
        "@value": "アニメ"
      },
      {
        "@language": "ru",
        "@value": "Аниме"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasMember",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega una Collezione a una delle entità che la costituiscono. L'appartenenza non implica esaustività né necessità."
      },
      {
        "@language": "en",
        "@value": "Relates a Collection to one of its constituent entities. Membership does not imply exhaustiveness or strict necessity."
      },
      {
        "@language": "nl",
        "@value": "Verbindt een collectie met een van de samenstellende entiteiten. Lidmaatschap impliceert geen volledigheid of strikte noodzaak."
      },
      {
        "@language": "ja",
        "@value": "エンティティと、それが構成要素となるコレクションを関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает коллекцию с одной из составляющих её сущностей. Принадлежность не подразумевает исчерпаемости или строгой необходимости."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Collection"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha membro"
      },
      {
        "@language": "en",
        "@value": "has member"
      },
      {
        "@language": "nl",
        "@value": "heeft lid"
      },
      {
        "@language": "ja",
        "@value": "構成要素"
      },
      {
        "@language": "ru",
        "@value": "имеет участника/элемент"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2002/07/owl#Thing"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/isMemberOf"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Country",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A geopolitical location representing a nation or state."
      },
      {
        "@language": "it",
        "@value": "Una località geopolitica che rappresenta una nazione o uno stato."
      },
      {
        "@language": "nl",
        "@value": "Een geopolitieke locatie die een natie of staat vertegenwoordigt."
      },
      {
        "@language": "ja",
        "@value": "国家または州を表す地政学的場所。"
      },
      {
        "@language": "ru",
        "@value": "Геополитическая локация, представляющая собой нацию или государство."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Country"
      },
      {
        "@language": "it",
        "@value": "Paese"
      },
      {
        "@language": "nl",
        "@value": "Land"
      },
      {
        "@language": "ja",
        "@value": "国"
      },
      {
        "@language": "ru",
        "@value": "Страна"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Location"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasCreator",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega un'Estetica all'Agente che l'ha creata o a cui essa deve la propria origine."
      },
      {
        "@language": "en",
        "@value": "Relates an Aesthetic to the Agent who created or gave rise to it."
      },
      {
        "@language": "nl",
        "@value": "Verbindt een esthetiek met de agent die deze heeft gecreëerd of aan wie het zijn oorsprong ontleent."
      },
      {
        "@language": "ja",
        "@value": "美学と、それを創造したまたは生み出したエージェントを関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает эстетику с агентом, который создал её или способствовал её появлению."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha creatore"
      },
      {
        "@language": "en",
        "@value": "has creator"
      },
      {
        "@language": "nl",
        "@value": "heeft maker"
      },
      {
        "@language": "ja",
        "@value": "クリエイター"
      },
      {
        "@language": "ru",
        "@value": "имеет создателя"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Agent"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/PrimaryRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role indicating a primary or central association within a context."
      },
      {
        "@language": "it",
        "@value": "Un ruolo che indica un’associazione primaria o centrale in un contesto."
      },
      {
        "@language": "nl",
        "@value": "Een rol die een primaire of centrale associatie binnen een context aangeeft."
      },
      {
        "@language": "ja",
        "@value": "文脈の中で主要または中心的な関連を示す役割。"
      },
      {
        "@language": "ru",
        "@value": "Роль, указывающая на первичную или центральную связь внутри контекста."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Primary Role"
      },
      {
        "@language": "it",
        "@value": "Ruolo primario"
      },
      {
        "@language": "nl",
        "@value": "Primaire rol"
      },
      {
        "@language": "ja",
        "@value": "主要役割"
      },
      {
        "@language": "ru",
        "@value": "Основная роль"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/Role"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/fashionDimension",
    "@type": [
      "http://www.w3.org/2002/07/owl#NamedIndividual"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "dimensione della moda"
      },
      {
        "@language": "en",
        "@value": "fashion dimension"
      },
      {
        "@language": "nl",
        "@value": "mode dimensie"
      },
      {
        "@language": "ja",
        "@value": "ファッションの次元"
      },
      {
        "@language": "ru",
        "@value": "измерение моды"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/ColorPalette",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A structured set of colors associated through recurrent co-occurrence, design conventions, or perceptual harmony, often contributing to the visual identity of an aesthetic."
      },
      {
        "@language": "it",
        "@value": "Un insieme strutturato di colori associati per co-occorrenza o armonia visiva, che spesso contribuisce all’identità di un’estetica."
      },
      {
        "@language": "nl",
        "@value": "Een gestructureerde set kleuren die verbonden zijn door herhaaldelijke co-occurrentie, ontwerpconventies of perceptuele harmonie, en die vaak bijdragen aan de visuele identiteit van een esthetiek."
      },
      {
        "@language": "ja",
        "@value": "反復的な共起、デザイン慣習、視覚的調和によって構造化された色のセット。特定の美学の視覚的アイデンティティの構成要素となることがある。"
      },
      {
        "@language": "ru",
        "@value": "Структурированный набор цветов, связанных через повторяющееся совместное использование, конвенции дизайна или гармонию восприятия; часто вносит вклад в визуальную идентичность эстетики."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Color Palette"
      },
      {
        "@language": "it",
        "@value": "Palette di colori"
      },
      {
        "@language": "nl",
        "@value": "Kleurenpalet"
      },
      {
        "@language": "ja",
        "@value": "カラーパレット"
      },
      {
        "@language": "ru",
        "@value": "Цветовая палитра"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasRelatedWork",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Associa un'Estetica a un'Opera considerata rappresentativa o tematicamente correlata."
      },
      {
        "@language": "en",
        "@value": "Associates an Aesthetic with an Artwork considered representative of or thematically related to it."
      },
      {
        "@language": "nl",
        "@value": "Associeert een esthetiek met een werk dat als representatief of thematisch gerelateerd wordt beschouwd."
      },
      {
        "@language": "ja",
        "@value": "美学と、それを代表するまたはテーマ的に関連すると見なされる作品を関連付ける。"
      },
      {
        "@language": "ru",
        "@value": "Ассоциирует эстетику с произведением, которое считается репрезентативным для неё или тематически связано с ней."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "ha opera associata"
      },
      {
        "@language": "en",
        "@value": "has related work"
      },
      {
        "@language": "nl",
        "@value": "heeft gerelateerd werk"
      },
      {
        "@language": "ja",
        "@value": "関連作品"
      },
      {
        "@language": "ru",
        "@value": "имеет ассоциирующееся произведение"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Artwork"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/relatedTo"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/hasOriginPeriod",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Specifica l'intervallo temporale durante il quale un'Estetica è emersa per la prima volta."
      },
      {
        "@language": "en",
        "@value": "Specifies the time interval during which an Aesthetic first emerged."
      },
      {
        "@language": "nl",
        "@value": "Specificeert het tijdsinterval waarin een esthetiek voor het eerst naar voren kwam."
      },
      {
