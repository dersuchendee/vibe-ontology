        "@value": "ha piattaforma"
      },
      {
        "@language": "en",
        "@value": "has platform"
      },
      {
        "@language": "nl",
        "@value": "heeft platform"
      },
      {
        "@language": "ja",
        "@value": "流通プラットフォーム"
      },
      {
        "@language": "ru",
        "@value": "имеет платформу"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Platform"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/relatedTo"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/follows",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty",
      "http://www.w3.org/2002/07/owl#TransitiveProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Indica che un'Estetica segue temporalmente o stilisticamente un'altra. Questa proprietà è transitiva."
      },
      {
        "@language": "en",
        "@value": "Indicates that one Aesthetic temporally or stylistically follows another. This property is transitive."
      },
      {
        "@language": "nl",
        "@value": "Geeft aan dat een esthetiek een andere temporeel of stylistisch volgt. Deze eigenschap is transitief."
      },
      {
        "@language": "ja",
        "@value": "ある美学が別の美学に時間的またはスタイル的に後続することを示す。この性質は推移的である。"
      },
      {
        "@language": "ru",
        "@value": "Указывает на то, что одна эстетика следует за другой во времени или стилистически. Свойство является транзитивным."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "follows"
      },
      {
        "@language": "it",
        "@value": "segue"
      },
      {
        "@language": "nl",
        "@value": "volgt"
      },
      {
        "@language": "ja",
        "@value": "後継する"
      },
      {
        "@language": "ru",
        "@value": "следует за"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Aesthetic"
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "https://w3id.org/vibe-ontology/precedes"
      }
    ]
  },
