  {
    "@id": "https://w3id.org/vibe-ontology/isRoleInTimeOf",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Collega un TimeIndexedRole alla Piattaforma il cui ruolo temporalmente situato viene descritto."
      },
      {
        "@language": "en",
        "@value": "Links a TimeIndexedRole to the Platform whose temporally situated role is being described."
      },
      {
        "@language": "nl",
        "@value": "Koppelt een TimeIndexedRole aan het platform waarvan de tijdsgebonden rol wordt beschreven."
      },
      {
        "@language": "ja",
        "@value": "TimeIndexedRoleと、その時間的に位置づけられた役割が記述されるプラットフォームを結びつける。"
      },
      {
        "@language": "ru",
        "@value": "Связывает временную роль (TimeIndexedRole) с платформой, чья обусловленная временем роль описывается."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/TimeIndexedRole"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "is role in time of"
      },
      {
        "@language": "it",
        "@value": "è ruolo nel tempo di"
      },
      {
        "@language": "nl",
        "@value": "is tijdsgebonden rol van"
      },
      {
        "@language": "ja",
        "@value": "時間的役割の対象"
      },
      {
        "@language": "ru",
        "@value": "является временной ролью для"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Platform"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/Subculture",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A socially situated group or network characterized by shared practices, values, and symbolic systems that differentiate it from broader cultural contexts, often contributing to the emergence and stabilization of specific aesthetics."
      },
      {
        "@language": "it",
        "@value": "Un gruppo o una rete socialmente situata caratterizzata da pratiche, valori e sistemi simbolici condivisi che la distinguono dal contesto culturale più ampio, contribuendo spesso all’emergere e alla stabilizzazione di specifiche estetiche."
      },
      {
        "@language": "nl",
        "@value": "Een sociaal gesitueerde groep of netwerk gekenmerkt door gedeelde praktijken, waarden en symbolische systemen die het onderscheiden van bredere culturele contexten, en vaak bijdragen aan het ontstaan en de stabilisatie van specifieke esthetiek."
      },
      {
        "@language": "ja",
        "@value": "独自の慣習や価値観、象徴体系を共有し、主流文化とは区別される社会的グループ。特定の美学の創発と定着を促す基盤となることがある。"
      },
      {
        "@language": "ru",
        "@value": "Социально локализованная группа или сеть, характеризующаяся общими практиками, ценностями и символическими системами, которые отличают её от более широкого культурного контекста; часто способствует возникновению и стабилизации определенных эстетик."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "Sottocultura"
      },
      {
        "@language": "en",
        "@value": "Subculture"
      },
      {
        "@language": "nl",
        "@value": "Subcultuur"
      },
      {
        "@language": "ja",
        "@value": "サブカルチャー"
      },
      {
        "@language": "ru",
        "@value": "Субкультура"
      }
    ]
  },
  {
    "@id": "https://w3id.org/vibe-ontology/source",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "it",
        "@value": "Indica l'Agente da cui una PeriodDefinition trae la propria evidenza o autorità."
      },
      {
        "@language": "en",
        "@value": "Indicates the Agent from which a PeriodDefinition derives its evidence or authority."
      },
      {
        "@language": "nl",
        "@value": "Geeft de actor aan waaraan een periodedefinitie zijn bewijs of autoriteit ontleent."
      },
      {
        "@language": "ja",
        "@value": "期間定義（PeriodDefinition）の根拠、あるいは権威的な裏付けとなるエージェント（出典元）を示す。  "
      },
      {
        "@language": "ru",
        "@value": "Указывает на агента, который является источником доказательств или авторитетным лицом для данного определения периода."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "https://w3id.org/vibe-ontology/PeriodDefinition"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "it",
        "@value": "fonte"
      },
      {
        "@language": "en",
        "@value": "source"
      },
      {
        "@language": "nl",
        "@value": "bron"
      },
      {
        "@language": "ja",
        "@value": "出典"
      },
      {
        "@language": "ru",
        "@value": "источник"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "https://w3id.org/vibe-ontology/Agent"
      }
    ]
  },
