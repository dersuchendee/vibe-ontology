        <IRI>/Videogame</IRI>
        <Literal xml:lang="en">An interactive digital artwork combining visual, narrative, and gameplay elements.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>/Videogame</IRI>
        <Literal xml:lang="nl">Een interactief digitaal kunstwerk dat visuele, narratieve en gameplay-elementen combineert.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>/Videogame</IRI>
        <Literal xml:lang="it">Un’opera digitale interattiva che combina elementi visivi, narrativi e ludici.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>/Videogame</IRI>
        <Literal xml:lang="ru">Интерактивное цифровое произведение, сочетающее визуальные, повествовательные и игровые элементы.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
