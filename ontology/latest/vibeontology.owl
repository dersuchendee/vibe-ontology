    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>/Album</IRI>
        <Literal xml:lang="nl">Een muzikaal werk bestaande uit een verzameling opgenomen tracks die als één geheel zijn uitgebracht.</Literal>
