        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>/associatedSubculture</IRI>
        <Literal xml:lang="nl">Koppelt een esthetiek aan een subcultuur die er sociaal mee geassocieerd is of heeft bijgedragen aan het ontstaan en de stabilisatie ervan.</Literal>
