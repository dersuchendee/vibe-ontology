                  "URL-адрес в вики (эстетика)"@ru ,
                  "ウィキデータURL（美学）"@ja ;
     rdfs:label "URL"@en ,
                "URL"@it ,
                "URL"@ja ,
                "URL"@nl ,
                "URL-адрес"@ru .


###  https://w3id.org/vibe-ontology/alternateName
:alternateName rdf:type owl:DatatypeProperty ;
               rdfs:domain :Aesthetic ;
               rdfs:range xsd:string ;
               rdfs:label "alternate name"@en ,
                          "alternatieve naam"@nl ,
                          "nome alternativo"@it ,
                          "альтернативное название"@ru ,
                          "別名"@ja .


###  https://w3id.org/vibe-ontology/approximateLabel
:approximateLabel rdf:type owl:DatatypeProperty ;
                  rdfs:domain :TimeInterval ;
                  rdfs:range xsd:string ;
                  rdfs:label "approximate label"@en ,
                             "bijna gelijk label"@nl ,
                             "etichetta approssimativa"@it ,
                             "приблизительная метка"@ru ,
                             "近似ラベル"@ja .


###  https://w3id.org/vibe-ontology/endYear
:endYear rdf:type owl:DatatypeProperty ;
         rdfs:domain :TimeInterval ;
         rdfs:range xsd:gYear ;
         rdfs:label "anno di fine"@it ,
                    "eindjaar"@nl ,
                    "end year"@en ,
                    "год окончания"@ru ,
                    "終了年"@ja .


###  https://w3id.org/vibe-ontology/name
:name rdf:type owl:DatatypeProperty ;
      rdfs:domain :Aesthetic ;
      rdfs:range xsd:string ;
      rdfs:label "naam"@nl ,
                 "name"@en ,
                 "nome"@it ,
                 "название"@ru ,
                 "名称"@ja .


###  https://w3id.org/vibe-ontology/representativenessType
:representativenessType rdf:type owl:DatatypeProperty ;
                        rdfs:domain :RepresentativeAssociation ;
                        rdfs:range xsd:string ;
                        rdfs:label "representativeness type"@en ,
                                   "representativiteit type"@nl ,
                                   "tipo di rappresentatività"@it ,
                                   "тип репрезентативности"@ru ,
                                   "象徴性タイプ"@ja .


