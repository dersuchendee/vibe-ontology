@prefix : <https://w3id.org/vibe-ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://w3id.org/vibe-ontology/> .

<https://w3id.org/vibe-ontology/> rdf:type owl:Ontology ;
                                   rdfs:comment "Ontologia per modellare le estetiche come categorie emergenti basate su collezioni e associazioni rappresentative."@it ,
                                                "Ontologie voor het modelleren van esthetiek als emergente, op collecties gebaseerde categorieën die geworteld zijn in representatieve associaties."@nl ,
                                                "Ontology for modelling aesthetics as emergent, collection-based categories grounded in representative associations."@en ,
                                                "Онтология для моделирования эстетики как эмерджентных, коллекционно-обусловленных категорий, основанных на репрезентативных ассоциациях."@ru ,
                                                "美学とその象徴的な表象との結びつきを基盤とし、多様な要素のコレクションから立ち現れる美学的系統をモデル化するためのオントロジー。"@ja ;
                                   rdfs:label "Ontologia Vibe"@it ,
                                              "Vibe Ontologie"@nl ,
                                              "Vibe Ontology"@en ,
                                              "Vibe オントロジー"@ja ,
                                              "Вайб Онтология"@ru .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#gYear
xsd:gYear rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#broader
<http://www.w3.org/2004/02/skos/core#broader> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
<http://www.w3.org/2004/02/skos/core#closeMatch> rdf:type owl:ObjectProperty .


###  http://www.w3.org/2004/02/skos/core#narrower
<http://www.w3.org/2004/02/skos/core#narrower> rdf:type owl:ObjectProperty ;
                                               owl:equivalentProperty :hasSubgenre .


###  https://w3id.org/vibe-ontology/associatedSubculture
:associatedSubculture rdf:type owl:ObjectProperty ;
                      rdfs:domain :Aesthetic ;
                      rdfs:range :Subculture ;
                      rdfs:comment "Collega un'Estetica a una Sottocultura che le è socialmente associata o ha contribuito alla sua emergenza e stabilizzazione."@it ,
                                   "Koppelt een esthetiek aan een subcultuur die er sociaal mee geassocieerd is of heeft bijgedragen aan het ontstaan en de stabilisatie ervan."@nl ,
                                   "Links an Aesthetic to a Subculture that is socially associated with it or contributed to its emergence and stabilization."@en ,
                                   "Связывает эстетику с субкультурой, которая ассоциируется с ней в обществе или способствовала её возникновению и стабилизации."@ru ,
                                   "美学と、社会的に関連の深いサブカルチャー、あるいはその出現や定着に寄与したサブカルチャーを結びつける。"@ja ;
                      rdfs:label "associated subculture"@en ,
                                 "geassocieerde subcultuur"@nl ,
                                 "sottocultura associata"@it ,
                                 "ассоциированная субкультура"@ru ,
                                 "関連サブカルチャー"@ja .


###  https://w3id.org/vibe-ontology/associationDimension
:associationDimension rdf:type owl:ObjectProperty ;
                      rdfs:domain :RepresentativeAssociation ;
                      rdfs:range owl:Thing ;
                      rdfs:comment "Classifica il tipo di associazione codificata da una RepresentativeAssociation. I valori attesi sono gli individui: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."@it ,
                                   "Classificeert het type associatie gecodeerd door een RepresentativeAssociation. Verwachte waarden zijn de individuen: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."@nl ,
                                   "Classifies the kind of association. Expected values are the named individuals: motifDimension, themeDimension, valueDimension, colorDimension, platformDimension, musicDimension, fashionDimension, iconicFigureDimension."@en ,
                                   "Классифицирует тип ассоциации. Ожидаемые значения — индивиды: измерение мотива (motifDimension), темы (themeDimension), ценности (valueDimension), цвета (colorDimension), платформы (platformDimension), музыки (musicDimension), моды (fashionDimension) или иконической фигуры (iconicFigureDimension)."@ru ,
                                   "関連性のレベルを分類するための属性。モチーフ、テーマ、価値観、色彩、プラットフォーム、音楽、ファッション、象徴的人物といった各次元を指定する。"@ja ;
                      rdfs:label "associatie dimensie"@nl ,
                                 "association dimension"@en ,
                                 "dimensione dell’associazione"@it ,
                                 "измерение ассоциации"@ru ,
                                 "関連の次元"@ja .


###  https://w3id.org/vibe-ontology/atTime
:atTime rdf:type owl:ObjectProperty ;
        rdfs:domain :TimeIndexedRole ;
        rdfs:range :TimeInterval ;
        rdfs:comment "Specifica l'intervallo temporale durante il quale un TimeIndexedRole è valido."@it ,
                     "Specificeert het tijdsinterval waarin een TimeIndexedRole geldig is."@nl ,
                     "Specifies the temporal interval during which a TimeIndexedRole is valid."@en ,
                     "TimeIndexedRoleが有効である時間区間を指定する。"@ja ,
                     "Указывает временной интервал, в течение которого роль (TimeIndexedRole) является действительной."@ru ;
        rdfs:label "al tempo"@it ,
                   "at time"@en ,
                   "op tijdstip"@nl ,
                   "во время"@ru ,
                   "時点"@ja .


###  https://w3id.org/vibe-ontology/coinedBy
:coinedBy rdf:type owl:ObjectProperty ;
          rdfs:domain :Aesthetic ;
          rdfs:range :Agent ;
          rdfs:comment "Collega un'Estetica all'Agente che l'ha coniata o che vi ha dato il nome per la prima volta."@it ,
                       "Relates an Aesthetic to the Agent who coined or first named it."@en ,
                       "Verbindt een esthetiek met de agent die deze heeft opgebracht of voor het eerst een naam heeft gegeven."@nl ,
                       "Связывает эстетику с агентом, который впервые ввел её название или термин."@ru ,
                       "美学と、それを作り出したまたは最初に名付けたエージェントを関連付ける。"@ja ;
          rdfs:label "coined by"@en ,
                     "coniato da"@it ,
                     "opgebracht door"@nl ,
                     "придумано (кем)"@ru ,
                     "命名者"@ja .


###  https://w3id.org/vibe-ontology/follows
:follows rdf:type owl:ObjectProperty ;
         owl:inverseOf :precedes ;
         rdf:type owl:TransitiveProperty ;
         rdfs:domain :Aesthetic ;
         rdfs:range :Aesthetic ;
         rdfs:comment "Geeft aan dat een esthetiek een andere temporeel of stylistisch volgt. Deze eigenschap is transitief."@nl ,
                      "Indica che un'Estetica segue temporalmente o stilisticamente un'altra. Questa proprietà è transitiva."@it ,
                      "Indicates that one Aesthetic temporally or stylistically follows another. This property is transitive."@en ,
                      "Указывает на то, что одна эстетика следует за другой во времени или стилистически. Свойство является транзитивным."@ru ,
                      "ある美学が別の美学に時間的またはスタイル的に後続することを示す。この性質は推移的である。"@ja ;
         rdfs:label "follows"@en ,
                    "segue"@it ,
                    "volgt"@nl ,
                    "следует за"@ru ,
                    "後継する"@ja .


###  https://w3id.org/vibe-ontology/forAesthetic
:forAesthetic rdf:type owl:ObjectProperty ;
              rdfs:domain :RepresentativeAssociation ;
              rdfs:range :Aesthetic ;
              rdfs:comment "Collega una AssociazioneRappresentativa all'Estetica che essa qualifica."@it ,
                           "Koppelt een RepresentativeAssociation aan de esthetiek die het kwalificeert."@nl ,
                           "Links a RepresentativeAssociation to the Aesthetic it qualifies."@en ,
                           "Связывает репрезентативную ассоциацию с конкретной эстетикой, которую она характеризует."@ru ,
                           "象徴的な関連（Representative Association）が、どの美学的系統を規定・説明しているかを示す。"@ja ;
              rdfs:label "for aesthetic"@en ,
                         "per estetica"@it ,
                         "voor esthetiek"@nl ,
                         "для эстетики"@ru ,
                         "対象"@ja .


###  https://w3id.org/vibe-ontology/hasColorPalette
:hasColorPalette rdf:type owl:ObjectProperty ;
                 rdfs:domain :Aesthetic ;
                 rdfs:range :ColorPalette ;
                 rdfs:comment "Associa un'Estetica a una palette di colori caratteristica che contribuisce alla sua identità visiva."@it ,
                              "Associates an Aesthetic with a characteristic ColorPalette that contributes to its visual identity."@en ,
                              "Associeert een esthetiek met een karakteristiek kleurenpalet dat bijdraagt aan de visuele identiteit."@nl ,
                              "Ассоциирует эстетику с характерной цветовой палитрой, определяющей её визуальную идентичность."@ru ,
                              "美学と、その視覚的アイデンティティに寄与する特徴的なカラーパレットを関連付ける。"@ja ;
                 rdfs:label "ha palette di colori"@it ,
                            "has color palette"@en ,
                            "heeft kleurenpalet"@nl ,
                            "имеет цветовую палитру"@ru ,
                            "カラーパレット"@ja .


###  https://w3id.org/vibe-ontology/hasCreator
:hasCreator rdf:type owl:ObjectProperty ;
            rdfs:domain :Aesthetic ;
            rdfs:range :Agent ;
            rdfs:comment "Collega un'Estetica all'Agente che l'ha creata o a cui essa deve la propria origine."@it ,
                         "Relates an Aesthetic to the Agent who created or gave rise to it."@en ,
                         "Verbindt een esthetiek met de agent die deze heeft gecreëerd of aan wie het zijn oorsprong ontleent."@nl ,
                         "Связывает эстетику с агентом, который создал её или способствовал её появлению."@ru ,
                         "美学と、それを創造したまたは生み出したエージェントを関連付ける。"@ja ;
            rdfs:label "ha creatore"@it ,
                       "has creator"@en ,
                       "heeft maker"@nl ,
                       "имеет создателя"@ru ,
                       "クリエイター"@ja .


###  https://w3id.org/vibe-ontology/hasIconicFigure
:hasIconicFigure rdf:type owl:ObjectProperty ;
                 rdfs:domain :Aesthetic ;
                 rdfs:range :Agent ;
                 rdfs:comment "Associa un'Estetica a un Agente considerato suo rappresentante emblematico."@it ,
                              "Associates an Aesthetic with an Agent who is considered an emblematic or iconic representative of it."@en ,
                              "Associeert een esthetiek met een agent die wordt beschouwd als een emblematische of iconische vertegenwoordiger ervan."@nl ,
                              "Ассоциирует эстетику с агентом, который считается её каноничным или культовым представителем."@ru ,
                              "美学と、その象徴的または典型的な代表者と見なされるエージェントを関連付ける。"@ja ;
                 rdfs:label "ha figura iconica"@it ,
                            "has iconic figure"@en ,
                            "heeft iconisch figuur"@nl ,
                            "имеет иконическую фигуру"@ru ,
                            "象徴的人物"@ja .


###  https://w3id.org/vibe-ontology/hasLocation
:hasLocation rdf:type owl:ObjectProperty ;
             rdfs:domain owl:Thing ;
             rdfs:range :Location ;
             rdfs:comment "Associa qualsiasi entità a una collocazione spaziale, fisica o digitale."@it ,
                          "Associates any entity with a physical or digital spatial location."@en ,
                          "Associeert elke entiteit met een fysieke of digitale ruimtelijke locatie."@nl ,
                          "Ассоциирует любую сущность с физическим или цифровым пространственным расположением."@ru ,
                          "任意のエンティティと物理的またはデジタルの空間的場所を関連付ける。"@ja ;
             rdfs:label "ha luogo"@it ,
                        "has location"@en ,
                        "heeft locatie"@nl ,
                        "имеет местоположение"@ru ,
                        "所在地"@ja .


###  https://w3id.org/vibe-ontology/hasLocationOfOrigin
:hasLocationOfOrigin rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf :hasLocation ;
                     rdfs:domain :Aesthetic ;
                     rdfs:range :Location ;
                     rdfs:comment "Specifica la collocazione geografica o digitale in cui un'Estetica ha avuto origine."@it ,
                                  "Specificeert de geografische of digitale locatie waar een esthetiek voor het eerst is ontstaan."@nl ,
                                  "Specifies the geographic or digital location where an Aesthetic first originated."@en ,
                                  "Указывает географическое или цифровое местоположение, в котором эстетика возникла впервые."@ru ,
                                  "美学と、それが最初に発祥した物理的またはデジタルの空間的場所を関連付ける。"@ja ;
                     rdfs:label "ha luogo di origine"@it ,
                                "has location of origin"@en ,
                                "heeft locatie van oorsprong"@nl ,
                                "место происхождения"@ru ,
                                "発祥地"@ja .


###  https://w3id.org/vibe-ontology/hasMember
:hasMember rdf:type owl:ObjectProperty ;
           owl:inverseOf :isMemberOf ;
           rdfs:domain :Collection ;
           rdfs:range owl:Thing ;
           rdfs:comment "Collega una Collezione a una delle entità che la costituiscono. L'appartenenza non implica esaustività né necessità."@it ,
                        "Relates a Collection to one of its constituent entities. Membership does not imply exhaustiveness or strict necessity."@en ,
                        "Verbindt een collectie met een van de samenstellende entiteiten. Lidmaatschap impliceert geen volledigheid of strikte noodzaak."@nl ,
                        "Связывает коллекцию с одной из составляющих её сущностей. Принадлежность не подразумевает исчерпаемости или строгой необходимости."@ru ,
                        "エンティティと、それが構成要素となるコレクションを関連付ける。"@ja ;
           rdfs:label "ha membro"@it ,
                      "has member"@en ,
                      "heeft lid"@nl ,
                      "имеет участника/элемент"@ru ,
                      "構成要素"@ja .


###  https://w3id.org/vibe-ontology/hasMotif
:hasMotif rdf:type owl:ObjectProperty ;
          rdfs:domain :Artwork ;
          rdfs:range :Motif ;
          rdfs:comment "Associa un'Opera d'arte a un motivo ricorrente e riconoscibile."@it ,
                       "Associates an Artwork with a recurrent and recognizable motif it exhibits."@en ,
                       "Associeert een kunstwerk met een terugkerend en herkenbaar motief dat het vertoont."@nl ,
                       "Ассоциирует произведение искусства с узнаваемым повторяющимся мотивом, который в нем присутствует."@ru ,
                       "作品と、その中に現れる特徴的なモチーフを関連付ける。"@ja ;
          rdfs:label "ha motivo"@it ,
                     "has motif"@en ,
                     "heeft motief"@nl ,
                     "имеет мотив"@ru ,
                     "モチーフ"@ja .


###  https://w3id.org/vibe-ontology/hasOriginPeriod
:hasOriginPeriod rdf:type owl:ObjectProperty ;
                 rdfs:domain :Aesthetic ;
                 rdfs:range :TimeInterval ;
                 rdfs:comment "Specifica l'intervallo temporale durante il quale un'Estetica è emersa per la prima volta."@it ,
                              "Specificeert het tijdsinterval waarin een esthetiek voor het eerst naar voren kwam."@nl ,
                              "Specifies the time interval during which an Aesthetic first emerged."@en ,
                              "Указывает временной интервал, в течение которого эстетика появилась впервые."@ru ,
                              "美学が最初に出現した期間を指定する。"@ja ;
                 rdfs:label "ha periodo di origine"@it ,
                            "has origin period"@en ,
                            "heeft periode van oorsprong"@nl ,
                            "период возникновения"@ru ,
                            "発祥期"@ja .


###  https://w3id.org/vibe-ontology/hasPeriodDefinition
:hasPeriodDefinition rdf:type owl:ObjectProperty ;
                     rdfs:domain owl:Thing ;
                     rdfs:range :PeriodDefinition ;
                     rdfs:comment "Associa un'entità a una Definizione di periodo che la colloca in un contesto temporale."@it ,
                                  "Associates an entity with a PeriodDefinition that situates it within a temporal context."@en ,
                                  "Associeert een entiteit met een periodedefinitie die deze binnen een temporele context plaatst."@nl ,
                                  "Ассоциирует сущность с Определением периода, помещая её в конкретный временной контекст."@ru ,
                                  "エンティティと、それを時間的文脈に位置づける期間定義を関連付ける。"@ja ;
                     rdfs:label "ha definizione di periodo"@it ,
                                "has period definition"@en ,
                                "heeft periodedefinitie"@nl ,
                                "имеет определение периода"@ru ,
                                "期間定義"@ja .


###  https://w3id.org/vibe-ontology/hasPlatform
:hasPlatform rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :relatedTo ;
             rdfs:domain :Aesthetic ;
             rdfs:range :Platform ;
             rdfs:comment "Associa un'Estetica a una Piattaforma su cui essa circola o è stata diffusa."@it ,
                          "Associates an Aesthetic with a Platform on which it circulates or has been disseminated."@en ,
                          "Associeert een esthetiek met een platform waarop deze circuleert of is verspreid."@nl ,
                          "Ассоциирует эстетику с платформой, на которой она распространяется."@ru ,
                          "美学と、それが流通しまたは普及したプラットフォームを関連付ける。"@ja ;
             rdfs:label "ha piattaforma"@it ,
                        "has platform"@en ,
                        "heeft platform"@nl ,
                        "имеет платформу"@ru ,
                        "流通プラットフォーム"@ja .


###  https://w3id.org/vibe-ontology/hasPrimaryPlatform
:hasPrimaryPlatform rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :hasPlatform ;
                    rdfs:domain :Aesthetic ;
                    rdfs:range :Platform ;
                    rdfs:comment "Specifica la Piattaforma principale attraverso cui un'Estetica è prevalentemente diffusa o ha acquisito visibilità."@it ,
                                 "Specificeert het belangrijkste platform waarlangs een esthetiek voornamelijk wordt verspreid of zichtbaarheid heeft verkregen."@nl ,
                                 "Specifies the main Platform through which an Aesthetic is primarily disseminated or has gained visibility."@en ,
                                 "Указывает на основную платформу, через которую эстетика преимущественно распространялась или получила известность."@ru ,
                                 "美学が主に普及、または認知を得た主要なプラットフォームを指定する。"@ja ;
                    rdfs:label "ha piattaforma principale"@it ,
                               "has primary platform"@en ,
                               "heeft primair platform"@nl ,
                               "имеет основную платформу"@ru ,
                               "主要プラットフォーム"@ja .


###  https://w3id.org/vibe-ontology/hasRelatedBrand
:hasRelatedBrand rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :relatedTo ;
                 rdfs:domain :Aesthetic ;
                 rdfs:range :Brand ;
                 rdfs:comment "Associa un'Estetica a un Brand che le è caratteristico o culturalmente affine."@it ,
                              "Associates an Aesthetic with a Brand that is characteristic of or culturally aligned with it."@en ,
                              "Associeert een esthetiek met een merk dat er kenmerkend voor is of er cultureel mee overeenstemt."@nl ,
                              "Ассоциирует эстетику с брендом, который является характерным для неё или близок ей по духу."@ru ,
                              "美学と、その特徴的な、または文化的に一致するブランドを関連付ける。"@ja ;
                 rdfs:label "ha brand associato"@it ,
                            "has related brand"@en ,
                            "heeft gerelateerd merk"@nl ,
                            "имеет ассоциирующийся бренд"@ru ,
                            "関連ブランド"@ja .


###  https://w3id.org/vibe-ontology/hasRelatedWork
:hasRelatedWork rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf :relatedTo ;
                rdfs:domain :Aesthetic ;
                rdfs:range :Artwork ;
                rdfs:comment "Associa un'Estetica a un'Opera considerata rappresentativa o tematicamente correlata."@it ,
                             "Associates an Aesthetic with an Artwork considered representative of or thematically related to it."@en ,
                             "Associeert een esthetiek met een werk dat als representatief of thematisch gerelateerd wordt beschouwd."@nl ,
                             "Ассоциирует эстетику с произведением, которое считается репрезентативным для неё или тематически связано с ней."@ru ,
                             "美学と、それを代表するまたはテーマ的に関連すると見なされる作品を関連付ける。"@ja ;
                rdfs:label "ha opera associata"@it ,
                           "has related work"@en ,
                           "heeft gerelateerd werk"@nl ,
                           "имеет ассоциирующееся произведение"@ru ,
                           "関連作品"@ja .


###  https://w3id.org/vibe-ontology/hasSubgenre
:hasSubgenre rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :relatedTo ;
             owl:inverseOf :isSubgenreOf ;
             rdfs:domain :Aesthetic ;
             rdfs:range :Aesthetic ;
             rdfs:comment "Collega un'Estetica a un'Estetica più specifica che ne costituisce una sottovariante."@it ,
                          "Relates an Aesthetic to a more specific Aesthetic that constitutes one of its subvariants."@en ,
                          "Verbindt een esthetiek met een specifiekere esthetiek die er een subvariant van vormt."@nl ,
                          "Связывает Эстетику с более узкой Эстетикой, являющейся её подвариантом."@ru ,
                          "美学と、その派生系統を構成する、より具体的な美学を関連付ける。"@ja ;
             rdfs:label "ha sottogenere"@it ,
                        "has subgenre"@en ,
                        "heeft subgenre"@nl ,
                        "имеет поджанр"@ru ,
                        "サブジャンル"@ja .


###  https://w3id.org/vibe-ontology/hasTheme
:hasTheme rdf:type owl:ObjectProperty ;
          rdfs:domain :Artwork ;
          rdfs:range :Theme ;
          rdfs:comment "Associa un'Opera a un Tema che esprime, veicola o mette in primo piano."@it ,
                       "Associates an Artwork with a Theme it conveys, expresses, or foregrounds."@en ,
                       "Associeert een werk met een thema dat het uitdrukt, uitdraagt of op de voorgrond plaatst."@nl ,
                       "Ассоциирует произведение с темой, которую оно выражает или выдвигает на первый план."@ru ,
                       "作品とそのテーマ（作品が伝え、表現し、または強調している主旨やトーン）を関連付ける。"@ja ;
          rdfs:label "ha tema"@it ,
                     "has theme"@en ,
                     "heeft thema"@nl ,
                     "имеет тему"@ru ,
                     "テーマ"@ja .


###  https://w3id.org/vibe-ontology/hasValue
:hasValue rdf:type owl:ObjectProperty ;
          rdfs:domain :Aesthetic ;
          rdfs:range :Value ;
          rdfs:comment "Associa un'Estetica a un Valore che ne caratterizza l'orientamento."@it ,
                       "Associates an Aesthetic with an abstract Value that characterizes its orientation."@en ,
                       "Associeert een esthetiek met een abstracte waarde die de oriëntatie ervan kenmerkt."@nl ,
                       "Ассоциирует эстетику с абстрактной ценностью, характеризующей её направленность."@ru ,
                       "美学と、その方向性を特徴づける抽象的な価値観を関連付ける。"@ja ;
          rdfs:label "ha valore"@it ,
                     "has value"@en ,
                     "heeft waarde"@nl ,
                     "имеет ценность"@ru ,
                     "価値観"@ja .


###  https://w3id.org/vibe-ontology/influenced
:influenced rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :relatedTo ;
            owl:inverseOf :influencedBy ;
            rdfs:domain :Aesthetic ;
            rdfs:range :Aesthetic ;
            rdfs:comment "Collega un'Estetica a un'altra Estetica che essa ha influenzato in termini di stile, motivi o valori, o altro."@it ,
                         "Relates an Aesthetic to another Aesthetic that it has influenced in terms of style, motifs, values, or other."@en ,
                         "Verbindt een esthetiek met een andere esthetiek die het heeft beïnvloed op het gebied van stijl, motieven, waarden of anderszins."@nl ,
                         "Связывает эстетику с другой эстетикой, на которую она оказала влияние (в стиле, мотивах, ценностях и т. д.)."@ru ,
                         "美学と、それがスタイル、モチーフ、価値観などの点で影響を与えた別の美学を関連付ける。"@ja ;
            rdfs:label "beïnvloedde"@nl ,
                       "ha influenzato"@it ,
                       "influenced"@en ,
                       "оказала влияние на"@ru ,
                       "影響を与えた"@ja .


###  https://w3id.org/vibe-ontology/influencedBy
:influencedBy rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :relatedTo ;
              rdfs:domain :Aesthetic ;
              rdfs:range :Aesthetic ;
              rdfs:comment "Collega un'Estetica a un'altra Estetica da cui essa ha tratto influenza stilistica, tematica o culturale."@it ,
                           "Relates an Aesthetic to another Aesthetic from which it has drawn stylistic, thematic, or cultural influence."@en ,
                           "Verbindt een esthetiek met een andere esthetiek waarvan het stilistische, thematische of culturele invloed heeft ondergaan."@nl ,
                           "Связывает эстетику с другой эстетикой, которая послужила источником стилистического, тематического или культурного влияния."@ru ,
                           "美学と、それがスタイル的、テーマ的、または文化的影響を受けた別の美学を関連付ける。"@ja ;
              rdfs:label "beïnvloed door"@nl ,
                         "influenced by"@en ,
                         "influenzato da"@it ,
                         "находится под влиянием"@ru ,
                         "影響を受けた"@ja .


###  https://w3id.org/vibe-ontology/isMemberOf
:isMemberOf rdf:type owl:ObjectProperty ;
            rdfs:domain owl:Thing ;
            rdfs:range :Collection ;
            rdfs:comment "Collega un'entità alla Collezione di cui è membro costituente."@it ,
                         "Relates an entity to the Collection of which it is a constituent member."@en ,
                         "Verbindt een entiteit met de collectie waarvan het een samenstellend lid is."@nl ,
                         "Связывает сущность с коллекцией, частью которой она является."@ru ,
                         "エンティティと、それが構成メンバーであるコレクションを関連付ける。"@ja ;
            rdfs:label "is lid van"@nl ,
                       "is member of"@en ,
                       "è membro di"@it ,
                       "является элементом"@ru ,
                       "のメンバーである"@ja .


###  https://w3id.org/vibe-ontology/isRoleInTimeOf
:isRoleInTimeOf rdf:type owl:ObjectProperty ;
                rdfs:domain :TimeIndexedRole ;
                rdfs:range :Platform ;
                rdfs:comment "Collega un TimeIndexedRole alla Piattaforma il cui ruolo temporalmente situato viene descritto."@it ,
                             "Koppelt een TimeIndexedRole aan het platform waarvan de tijdsgebonden rol wordt beschreven."@nl ,
                             "Links a TimeIndexedRole to the Platform whose temporally situated role is being described."@en ,
                             "TimeIndexedRoleと、その時間的に位置づけられた役割が記述されるプラットフォームを結びつける。"@ja ,
                             "Связывает временную роль (TimeIndexedRole) с платформой, чья обусловленная временем роль описывается."@ru ;
                rdfs:label "is role in time of"@en ,
                           "is tijdsgebonden rol van"@nl ,
                           "è ruolo nel tempo di"@it ,
                           "является временной ролью для"@ru ,
                           "時間的役割の対象"@ja .


###  https://w3id.org/vibe-ontology/isSubgenreOf
:isSubgenreOf rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :relatedTo ;
              rdfs:domain :Aesthetic ;
              rdfs:range :Aesthetic ;
              rdfs:comment "Collega un'Estetica a un'Estetica più ampia di cui essa è una sottovariante più specifica."@it ,
                           "Relates an Aesthetic to a broader Aesthetic of which it is a more specific subvariant."@en ,
                           "Verbindt een esthetiek met een bredere esthetiek waarvan het een specifiekere subvariant is."@nl ,
                           "Связывает эстетику с более широкой эстетикой, подвариантом которой она является."@ru ,
                           "美学と、それが属する上位ジャンル、親ジャンル（より広い美学）を関連付ける。"@ja ;
              rdfs:label "is subgenre of"@en ,
                         "is subgenre van"@nl ,
                         "è sottogenere di"@it ,
                         "является поджанром"@ru ,
                         "上位ジャンル"@ja .


###  https://w3id.org/vibe-ontology/overlapsWith
:overlapsWith rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf :relatedTo ;
              rdf:type owl:SymmetricProperty ;
              rdfs:domain :Aesthetic ;
              rdfs:range :Aesthetic ;
              rdfs:comment "Geeft aan dat twee esthetieken significante elementen of associaties delen, zonder dat de een een subgenre van de ander is. Deze eigenschap is symmetrisch."@nl ,
                           "Indica che due Estetiche condividono elementi o associazioni significativi, senza che l'una sia sottogenere dell'altra. Questa proprietà è simmetrica."@it ,
                           "Indicates that two Aesthetics share significant elements or associations without either being a subgenre of the other. This property is symmetric."@en ,
                           "Указывает на то, что две эстетики имеют общие значимые элементы или ассоциации, при этом ни одна не является поджанром другой. Свойство симметрично."@ru ,
                           "二つの美学が、どちらも相手のサブジャンルではなく、重要な要素や関連を共有することを示す。この性質は対称的である。"@ja ;
              rdfs:label "overlaps with"@en ,
                         "overlapt met"@nl ,
                         "si sovrappone a"@it ,
                         "пересекается с"@ru ,
                         "重複する"@ja .


###  https://w3id.org/vibe-ontology/precedes
:precedes rdf:type owl:ObjectProperty ,
                   owl:TransitiveProperty ;
          rdfs:domain :Aesthetic ;
          rdfs:range :Aesthetic ;
          rdfs:comment "Geeft aan dat een esthetiek een andere temporeel of stylistisch voorafgaat. Deze eigenschap is transitief."@nl ,
                       "Indica che un'Estetica precede temporalmente o stilisticamente un'altra. Questa proprietà è transitiva."@it ,
                       "Indicates that one Aesthetic temporally or stylistically precedes another. This property is transitive."@en ,
                       "Указывает на то, что одна эстетика предшествует другой во времени или стилистически. Свойство транзитивно."@ru ,
                       "ある美学が別の美学に時間的またはスタイル的に先行することを示す。この性質は推移的である。"@ja ;
          rdfs:label "gaat vooraf aan"@nl ,
                     "precede"@it ,
                     "precedes"@en ,
                     "предшествует"@ru ,
                     "先行する"@ja .


###  https://w3id.org/vibe-ontology/relatedTo
:relatedTo rdf:type owl:ObjectProperty ,
                    owl:SymmetricProperty ;
           rdfs:domain :Aesthetic ;
           rdfs:range owl:Thing ;
           rdfs:comment "A general symmetric relation indicating that an Aesthetic is related to another entity in some culturally relevant way. Serves as a superproperty for more specific relation types."@en ,
                        "Een algemene symmetrische relatie die aangeeft dat een esthetiek gerelateerd is aan een andere entiteit op een cultureel relevante manier. Dient als superproperty voor specifiekere relatietypen."@nl ,
                        "Una relazione simmetrica generale che indica che un'Estetica è correlata a un'altra entità in modo culturalmente rilevante. Funge da superpropietà per tipi di relazione più specifici."@it ,
                        "Общее симметричное отношение, указывающее на культурную связь эстетики с другой сущностью. Служит суперсвойством для более специфичных типов отношений."@ru ,
                        "美学が文化的に関連する方法で別のエンティティと関連することを示す一般的な対称関係。より具体的な関係タイプのスーパープロパティとして機能する。"@ja ;
           rdfs:label "associato a"@it ,
                      "gerelateerd aan"@nl ,
                      "related to"@en ,
                      "связано с"@ru ,
                      "関連する"@ja .


###  https://w3id.org/vibe-ontology/source
:source rdf:type owl:ObjectProperty ;
        rdfs:domain :PeriodDefinition ;
        rdfs:range :Agent ;
        rdfs:comment "Geeft de actor aan waaraan een periodedefinitie zijn bewijs of autoriteit ontleent."@nl ,
                     "Indica l'Agente da cui una PeriodDefinition trae la propria evidenza o autorità."@it ,
                     "Indicates the Agent from which a PeriodDefinition derives its evidence or authority."@en ,
                     "Указывает на агента, который является источником доказательств или авторитетным лицом для данного определения периода."@ru ,
                     "期間定義（PeriodDefinition）の根拠、あるいは権威的な裏付けとなるエージェント（出典元）を示す。  "@ja ;
        rdfs:label "bron"@nl ,
                   "fonte"@it ,
                   "source"@en ,
                   "источник"@ru ,
                   "出典"@ja .


###  https://w3id.org/vibe-ontology/timeInterval
:timeInterval rdf:type owl:ObjectProperty ;
              rdfs:domain :PeriodDefinition ;
              rdfs:range :TimeInterval ;
              rdfs:comment "Collega una PeriodDefinition all'intervallo temporale che essa definisce."@it ,
                           "Koppelt een periodedefinitie aan het tijdsinterval dat het definieert."@nl ,
                           "Links a PeriodDefinition to the TimeInterval it defines."@en ,
                           "Связывает определение периода с временным интервалом, который оно описывает."@ru ,
                           "期間定義と、それが定義する時間区間を結びつける。"@ja ;
              rdfs:label "intervallo temporale"@it ,
                         "tijdsinterval"@nl ,
                         "time interval"@en ,
                         "временной интервал"@ru ,
                         "時間区間"@ja .


###  https://w3id.org/vibe-ontology/withEntity
:withEntity rdf:type owl:ObjectProperty ;
            rdfs:domain :RepresentativeAssociation ;
            rdfs:range owl:Thing ;
            rdfs:comment "Collega una RepresentativeAssociation all'entità considerata rappresentativa dell'Estetica."@it ,
                         "Koppelt een RepresentativeAssociation aan de entiteit die als representatief voor de esthetiek wordt beschouwd."@nl ,
                         "Links a RepresentativeAssociation to the entity that is considered representative of the Aesthetic."@en ,
                         "RepresentativeAssociationと、美学の象徴的な表象と見なされるエンティティを結びつける。"@ja ,
                         "Связывает репрезентативную ассоциацию с сущностью, которая считается характерной для данной эстетики."@ru ;
            rdfs:label "con entità"@it ,
                       "met entiteit"@nl ,
                       "with entity"@en ,
                       "с сущностью"@ru ,
                       "対象エンティティ"@ja .


###  https://w3id.org/vibe-ontology/withRole
:withRole rdf:type owl:ObjectProperty ;
          rdfs:domain :TimeIndexedRole ;
          rdfs:range :Role ;
          rdfs:comment "Specifica il Ruolo ricoperto dall'entità all'interno di una relazione di tipo Ruolo indicizzato temporalmente."@it ,
                       "Specificeert de rol die de entiteit vervult binnen een tijdgeïndexeerde rolrelatie."@nl ,
                       "Specifies the Role held by the entity within a TimeIndexedRole relation."@en ,
                       "Определяет Роль, которую сущность играет в рамках отношения временной роли (TimeIndexedRole)."@ru ,
                       "特定の関係性や時間的な枠組みにおいて、エンティティが担っている具体的な役割を示す。"@ja ;
          rdfs:label "con ruolo"@it ,
                     "met rol"@nl ,
                     "with role"@en ,
                     "с ролью"@ru ,
                     "役割"@ja .


